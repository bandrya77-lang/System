  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <a href="/dashboard" class="footer-logo nav-link">
      <img src="https://res.cloudinary.com/difucqa9h/image/upload/v1770643265/discord_images/yaix1pbnbdv3srvf12gl.png" alt="CODE NEXUS" />
      <span>CODE NEXUS</span>
    </a>
    <p>&copy; <%= new Date().getFullYear() %> CODE NEXUS</p>
  </footer>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <!-- Page in overlay -->
  <div id="ov" style="position:fixed;inset:0;z-index:9999;background:#040010;animation:pIn .45s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;"></div>

  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    /* ── Canvas background ── */
    (function () {
      const canvas = document.getElementById('c');
      const ctx = canvas.getContext('2d');
      let W, H, particles = [];
      function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
      function rand(a, b) { return Math.random() * (b - a) + a; }
      function init() {
        resize();
        particles = Array.from({ length: 60 }, () => ({
          x: rand(0, W), y: rand(0, H), r: rand(0.4, 1.4),
          dx: rand(-0.18, 0.18), dy: rand(-0.12, 0.12),
          o: rand(0.08, 0.28)
        }));
      }
      function draw() {
        ctx.clearRect(0, 0, W, H);
        particles.forEach(p => {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(167,139,250,${p.o})`;
          ctx.fill();
          p.x += p.dx; p.y += p.dy;
          if (p.x < 0) p.x = W; if (p.x > W) p.x = 0;
          if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
        });
        requestAnimationFrame(draw);
      }
      window.addEventListener('resize', () => { resize(); });
      init(); draw();
    })();

    /* ── Lucide icons ── */
    lucide.createIcons();

    /* ── Banner solid color ── */
    const bannerSolid = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;

    /* ── Profile sidebar ── */
    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn      = document.getElementById('open-profile');
    const closeBtn     = document.getElementById('close-profile');
    const copyId       = document.getElementById('prof-copy-id');

    function openProfile()  { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }

    if (openBtn) openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    if (profBackdrop) profBackdrop.addEventListener('click', closeProfile);

    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '✓ Copied!';
          copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }

    /* ── Language select ── */
    const langSelectEl = document.getElementById('lang-select');
    if (langSelectEl) {
      langSelectEl.addEventListener('change', function () {
        const u = new URL(window.location.href);
        u.searchParams.set('lang', this.value);
        window.location.href = u.toString();
      });
    }

    /* ── Mobile nav toggle ── */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');

    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; }
    function openNav()   { if (navSidebar) { navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; } }
    function closeNav()  { if (navSidebar) { navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; } }

    if (menuToggle) menuToggle.addEventListener('click', () => mgmtSidebar.classList.contains('open') ? closeMgmt() : openMgmt());
    if (navOverlay) navOverlay.addEventListener('click', () => { closeMgmt(); closeNav(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeMgmt(); closeNav(); closeProfile(); } });

    const sortBtn = document.querySelector('.mgmt-sort-btn');
    if (sortBtn) {
      sortBtn.addEventListener('click', function () {
        if (navSidebar && navSidebar.classList.contains('open')) { closeNav(); } else { closeMgmt(); openNav(); }
      });
    }

    /* ── Mgmt section collapse ── */
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const body = this.nextElementSibling;
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        this.classList.toggle('open', !isOpen);
      });
    });

    /* ── Utility: toggle edit panels ── */
    function toggleEditPanel(btn) {
      const targetId = btn.dataset.target;
      const panel = document.getElementById(targetId);
      const isOpen = panel.classList.contains('open');
      document.querySelectorAll('.cmd-edit-panel.open').forEach(p => p.classList.remove('open'));
      document.querySelectorAll('.cmd-edit-btn.active').forEach(b => b.classList.remove('active'));
      if (!isOpen) { panel.classList.add('open'); btn.classList.add('active'); }
    }

    /* ── Alias chip input ── */
    function handleAliasKey(e, input) {
      if ((e.key === 'Enter' || e.key === ',') && input.value.trim()) {
        e.preventDefault();
        const val = input.value.replace(',', '').trim();
        if (!val) return;
        const wrap = input.closest('.alias-input-wrap');
        const chip = document.createElement('span');
        chip.className = 'alias-chip';
        chip.innerHTML = val + '<button type="button" onclick="removeAlias(this)" tabindex="-1">×</button>';
        wrap.insertBefore(chip, input);
        input.value = '';
        markDirty();
      } else if (e.key === 'Backspace' && !input.value) {
        const chips = input.closest('.alias-input-wrap').querySelectorAll('.alias-chip');
        if (chips.length) { chips[chips.length - 1].remove(); markDirty(); }
      }
    }
    function removeAlias(btn) { btn.closest('.alias-chip').remove(); markDirty(); }

    /* ── Custom multi-select ── */
    function toggleCsel(display) {
      const dropdown = display.nextElementSibling;
      const isOpen = dropdown.classList.contains('open');
      document.querySelectorAll('.csel-dropdown.open').forEach(d => { d.classList.remove('open'); d.previousElementSibling.classList.remove('open'); });
      if (!isOpen) { dropdown.classList.add('open'); display.classList.add('open'); }
    }
    function toggleCselOption(opt, id, name) {
      opt.classList.toggle('selected');
      const isSelected = opt.classList.contains('selected');
      const display = opt.closest('.csel-dropdown').previousElementSibling;
      const placeholder = display.querySelector('.csel-placeholder');
      if (isSelected) {
        if (placeholder) placeholder.style.display = 'none';
        const chip = document.createElement('span');
        chip.className = 'csel-chip'; chip.dataset.id = id; chip.textContent = name;
        display.insertBefore(chip, display.querySelector('.csel-arrow'));
      } else {
        display.querySelectorAll('.csel-chip').forEach(c => { if (c.dataset.id === String(id)) c.remove(); });
        if (!display.querySelectorAll('.csel-chip').length && placeholder) placeholder.style.display = '';
      }
      markDirty();
    }
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.csel-wrap')) {
        document.querySelectorAll('.csel-dropdown.open').forEach(d => { d.classList.remove('open'); d.previousElementSibling.classList.remove('open'); });
      }
    });

    /* ── Save Bar: Utility ── */
    const saveBar  = document.getElementById('save-bar');
    const saveBtn  = document.getElementById('save-btn');
    const resetBtn = document.getElementById('reset-btn');

    function markDirty() {
      if (saveBar) saveBar.classList.add('visible');
    }

    function showToast(msg, type) {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = msg; t.className = 'toast ' + (type || 'success');
      void t.offsetWidth;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3000);
    }

    /* cmd enable/disable toggles */
    document.querySelectorAll('.cmd-main-toggle').forEach(sw => sw.addEventListener('change', markDirty));
    /* auto-delete toggles */
    document.querySelectorAll('.sw-input[data-field]').forEach(sw => sw.addEventListener('change', markDirty));

    /* Reset — reload page to discard */
    resetBtn?.addEventListener('click', () => window.location.reload());

    /* Save */
    saveBtn?.addEventListener('click', async () => {
      saveBtn.disabled = true;
      const origHTML = saveBtn.innerHTML;
      saveBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>&nbsp;<%= lang === "ar" ? "جاري الحفظ..." : "Saving..." %>';
      try {
        const cmdsPayload = {};
        document.querySelectorAll('.cmd-row').forEach(row => {
          const mainToggle = row.querySelector('.cmd-main-toggle');
          if (!mainToggle) return;
          const key = mainToggle.dataset.cmdKey;
          const panel = document.getElementById('edit-' + key);
          if (!panel) return;
          const aliases = [...panel.querySelectorAll('.alias-chip')].map(chip => chip.childNodes[0].textContent.trim());
          const getSelected = f => [...(panel.querySelector('.csel-wrap[data-field="' + f + '"]')?.querySelectorAll('.csel-chip') || [])].map(c => c.dataset.id);
          cmdsPayload[key] = {
            enabled: mainToggle.checked,
            aliases,
            ignoredChannels: getSelected('ignoredChannels'),
            ignoredRoles: getSelected('ignoredRoles'),
            enabledChannels: getSelected('enabledChannels'),
            allowedRoles: getSelected('allowedRoles'),
            autoDeleteAuthor: panel.querySelector('.sw-input[data-field="autoDeleteAuthor"]')?.checked || false,
            autoDeleteReply: panel.querySelector('.sw-input[data-field="autoDeleteReply"]')?.checked || false,
          };
        });
        const res = await fetch('/dashboard/<%= guildId %>/utility/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ commands: cmdsPayload }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        saveBar.classList.remove('visible');
        showToast('<%= lang === "ar" ? "تم الحفظ بنجاح ✓" : "Saved successfully ✓" %>');
      } catch (err) {
        showToast(err.message || '<%= lang === "ar" ? "حدث خطأ" : "An error occurred" %>', 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.innerHTML = origHTML;
      }
    });

    /* ── Page transitions ── */
    function fadeOut(href) {
      const ov = document.getElementById('ov');
      ov.classList.add('leave');
      setTimeout(() => { window.location.href = href; }, 360);
    }
    document.querySelectorAll('a.nav-link, a#logout-link').forEach(a => {
      a.addEventListener('click', function (e) {
        if (this.target === '_blank') return;
        e.preventDefault(); fadeOut(this.href);
      });
    });
  </script>
</body>
</html>

