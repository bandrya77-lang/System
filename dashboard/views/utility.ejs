    </div>
  </aside>

  <!-- Main content -->
  <main class="main">

    <!-- ── Module header ── -->
    <div class="util-module-header">
      <div>
        <h2><%= lang === 'ar' ? 'الأوامر العامة' : 'Utility' %></h2>
        <p><%= lang === 'ar' ? 'يحتوي على أوامر عامة متنوعة للمهام الشائعة ومعلومات السيرفر.' : 'Contains various general commands for common tasks and server information.' %></p>
      </div>
      <label class="sw-wrap" title="<%= lang === 'ar' ? 'تفعيل / إيقاف' : 'Enable / Disable' %>">
        <input type="checkbox" class="sw-input" data-field="moduleEnabled" checked>
        <span class="sw-track"><span class="sw-thumb"></span></span>
      </label>
    </div>

    <div class="divider"></div>

    <!-- ── Tabs ── -->
    <div class="util-tabs">
      <button class="util-tab active"><%= lang === 'ar' ? 'الأوامر' : 'Commands' %></button>
    </div>

    <!-- ── Commands Card ── -->
    <div class="card" style="padding:0; overflow:hidden;">
      <div style="padding:18px 20px 14px; display:flex; align-items:center; gap:10px;">
        <i data-lucide="terminal" style="width:17px;height:17px;color:#a78bfa;flex-shrink:0;stroke:currentColor;fill:none;"></i>
        <h3 style="font-size:1rem;font-weight:700;"><%= lang === 'ar' ? 'الأوامر' : 'Commands' %></h3>
      </div>
      <div class="divider" style="margin:0;"></div>

      <div class="cmd-list">
        <%
          const cmdMeta = {
            afk:           { en: 'Set yourself as AFK',                       ar: 'تعيين حالة AFK' },
            avatar:        { en: "View a member's or server's avatar",         ar: 'عرض صورة عضو أو السيرفر' },
            help:          { en: 'See information about the bot',              ar: 'معلومات عن البوت' },
            banner_server: { en: 'View the server banner',                     ar: 'عرض بانر السيرفر' },
            banner_user:   { en: "View a member's banner",                     ar: 'عرض بانر العضو' },
            ping:          { en: 'Shows bot latency',                          ar: 'إظهار تأخير البوت' },
            roles:         { en: 'View all server roles',                      ar: 'عرض رتب السيرفر' },
            user:          { en: 'View member profile details',                ar: 'عرض تفاصيل ملف العضو' },
            logo_server:   { en: 'View the server logo (icon)',                ar: 'عرض أيقونة السيرفر' },
          };
          const acts = (typeof utilityActions !== 'undefined') ? utilityActions : [];
        %>
        <% acts.forEach(function(cmd) { %>
        <div class="cmd-row" id="cmdrow-<%= cmd.key %>">
          <!-- ── Row main ── -->
          <div class="cmd-row-main">
            <div class="cmd-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 18 18">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M2 4.75C2 3.23079 3.23079 2 4.75 2H13.25C14.7692 2 16 3.23079 16 4.75V13.25C16 14.7692 14.7692 16 13.25 16H4.75C3.23079 16 2 14.7692 2 13.25V4.75Z" fill="currentColor" fill-opacity="0.4"/>
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9 12.25C9 11.8358 9.33579 11.5 9.75 11.5H12.25C12.6642 11.5 13 11.8358 13 12.25C13 12.6642 12.6642 13 12.25 13H9.75C9.33579 13 9 12.6642 9 12.25Z" fill="currentColor"/>
                <path fill-rule="evenodd" clip-rule="evenodd" d="M5.21967 6.71967C5.51256 6.42678 5.98744 6.42678 6.28033 6.71967L8.78033 9.21967C9.07322 9.51256 9.07322 9.98744 8.78033 10.2803L6.28033 12.7803C5.98744 13.0732 5.51256 13.0732 5.21967 12.7803C4.92678 12.4874 4.92678 12.0126 5.21967 11.7197L7.18934 9.75L5.21967 7.78033C4.92678 7.48744 4.92678 7.01256 5.21967 6.71967Z" fill="currentColor"/>
              </svg>
            </div>
            <div class="cmd-info">
              <div class="cmd-name"><%= cmd.key %></div>
              <div class="cmd-desc"><%= (cmdMeta[cmd.key] || {})[lang] || '' %></div>
            </div>
            <div class="cmd-actions">
              <button class="cmd-edit-btn" data-target="edit-<%= cmd.key %>" onclick="toggleEditPanel(this)" title="<%= lang === 'ar' ? 'تعديل' : 'Edit' %>">
                <i data-lucide="pencil" style="width:15px;height:15px;stroke:currentColor;fill:none;pointer-events:none;"></i>
              </button>
              <label class="sw-wrap" title="<%= lang === 'ar' ? 'تفعيل / إيقاف' : 'Enable / Disable' %>">
                <input type="checkbox" class="sw-input cmd-main-toggle" data-cmd-key="<%= cmd.key %>" <%= cmd.enabled ? 'checked' : '' %>>
