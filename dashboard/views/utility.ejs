            <div class="edit-panel-title">
              <i data-lucide="settings-2" style="width:15px;height:15px;stroke:currentColor;fill:none;flex-shrink:0;"></i>
              <%= lang === 'ar' ? 'الصلاحيات والمستعارات' : 'Permissions & Aliases' %>
