                    <span class="alias-chip"><%= alias %><button type="button" onclick="removeAlias(this)" tabindex="-1">×</button></span>
                  <% }); %>
                  <input class="alias-real-input" type="text"
                    placeholder="<%= lang === 'ar' ? 'أضف مستعاراً ثم اضغط Enter...' : 'Type then press Enter to add...' %>"
                    onkeydown="handleAliasKey(event,this)">
                </div>
                <div class="edit-vars-box">
                  <span class="edit-vars-title"><%= lang === 'ar' ? 'المتغيرات' : 'Variables' %></span>
                  <div class="edit-var-row">
                    <span class="edit-var-code"><%= typeof botPrefix !== 'undefined' ? botPrefix : '!' %></span>
                    <span class="edit-var-sep">–</span>
                    <span class="edit-var-desc">
                      <%= lang === 'ar' ? 'بادئة البوت' : "Bot's prefix" %>
                      &nbsp;·&nbsp;
                      <a href="/dashboard/<%= guildId %>/setting" class="nav-link" style="color:#a78bfa;font-size:.78rem;text-decoration:none;opacity:.85;transition:opacity .15s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='.85'">
                        <i data-lucide="external-link" style="width:11px;height:11px;stroke:currentColor;fill:none;display:inline;vertical-align:middle;"></i>
                        <%= lang === 'ar' ? 'تغيير' : 'Change' %>
                      </a>
                    </span>
                  </div>
                </div>
              </div>

              <!-- Ignored Channels -->
              <div class="edit-field">
                <span class="edit-label"><%= lang === 'ar' ? 'القنوات المتجاهلة' : 'Ignored Channels' %></span>
                <div class="csel-wrap" data-field="ignoredChannels">
                  <div class="csel-display" onclick="toggleCsel(this)">
                    <span class="csel-placeholder"><%= lang === 'ar' ? 'اختر...' : 'Select...' %></span>
                    <i data-lucide="chevrons-up-down" class="csel-arrow" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
                  </div>
                  <div class="csel-dropdown">
                    <% guildChannels.forEach(function(ch) { %>
                      <div class="csel-option" onclick="toggleCselOption(this,'<%= ch.id %>','#<%= ch.name %>')">
                        <div class="csel-option-check"></div>
                        <span>#<%= ch.name %></span>
                      </div>
                    <% }); %>
                    <% if (!guildChannels.length) { %><div style="padding:8px 10px;font-size:.8rem;color:var(--muted);"><%= lang==='ar'?'لا توجد قنوات':'No channels' %></div><% } %>
                  </div>
                </div>
              </div>

              <!-- Ignored Roles -->
              <div class="edit-field">
                <span class="edit-label"><%= lang === 'ar' ? 'الرتب المتجاهلة' : 'Ignored Roles' %></span>
                <div class="csel-wrap" data-field="ignoredRoles">
                  <div class="csel-display" onclick="toggleCsel(this)">
                    <span class="csel-placeholder"><%= lang === 'ar' ? 'اختر...' : 'Select...' %></span>
                    <i data-lucide="chevrons-up-down" class="csel-arrow" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
                  </div>
                  <div class="csel-dropdown">
                    <% guildRoles.forEach(function(r) { %>
                      <div class="csel-option" onclick="toggleCselOption(this,'<%= r.id %>','<%= r.name %>')">
                        <div class="csel-option-check"></div>
                        <span><%= r.name %></span>
                      </div>
                    <% }); %>
                    <% if (!guildRoles.length) { %><div style="padding:8px 10px;font-size:.8rem;color:var(--muted);"><%= lang==='ar'?'لا توجد رتب':'No roles' %></div><% } %>
                  </div>
                </div>
              </div>

              <!-- Enabled Channels -->
              <div class="edit-field">
                <span class="edit-label"><%= lang === 'ar' ? 'القنوات المفعلة' : 'Enabled Channels' %></span>
                <div class="csel-wrap" data-field="enabledChannels">
                  <div class="csel-display" onclick="toggleCsel(this)">
                    <span class="csel-placeholder"><%= lang === 'ar' ? 'اختر...' : 'Select...' %></span>
                    <i data-lucide="chevrons-up-down" class="csel-arrow" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
                  </div>
                  <div class="csel-dropdown">
                    <% guildChannels.forEach(function(ch) { %>
                      <div class="csel-option" onclick="toggleCselOption(this,'<%= ch.id %>','#<%= ch.name %>')">
                        <div class="csel-option-check"></div>
                        <span>#<%= ch.name %></span>
                      </div>
                    <% }); %>
                    <% if (!guildChannels.length) { %><div style="padding:8px 10px;font-size:.8rem;color:var(--muted);"><%= lang==='ar'?'لا توجد قنوات':'No channels' %></div><% } %>
                  </div>
                </div>
              </div>

              <!-- Allowed Roles -->
              <div class="edit-field">
                <span class="edit-label"><%= lang === 'ar' ? 'الرتب المسموحة' : 'Allowed Roles' %></span>
                <div class="csel-wrap" data-field="allowedRoles">
                  <div class="csel-display" onclick="toggleCsel(this)">
                    <span class="csel-placeholder"><%= lang === 'ar' ? 'اختر...' : 'Select...' %></span>
                    <i data-lucide="chevrons-up-down" class="csel-arrow" style="width:14px;height:14px;stroke:currentColor;fill:none;"></i>
                  </div>
                  <div class="csel-dropdown">
                    <% guildRoles.forEach(function(r) { %>
                      <div class="csel-option" onclick="toggleCselOption(this,'<%= r.id %>','<%= r.name %>')">
                        <div class="csel-option-check"></div>
                        <span><%= r.name %></span>
                      </div>
                    <% }); %>
                    <% if (!guildRoles.length) { %><div style="padding:8px 10px;font-size:.8rem;color:var(--muted);"><%= lang==='ar'?'لا توجد رتب':'No roles' %></div><% } %>
                  </div>
                </div>
              </div>

              <!-- Auto Delete Author's Message -->
              <div class="edit-field">
                <div class="edit-toggle-row">
                  <span class="edit-toggle-label"><%= lang === 'ar' ? 'حذف رسالة المستخدم تلقائياً' : "Auto Delete Author's Message" %></span>
                  <label class="sw-wrap">
                    <input type="checkbox" class="sw-input" data-field="autoDeleteAuthor">
                    <span class="sw-track"><span class="sw-thumb"></span></span>
                  </label>
                </div>
              </div>

              <!-- Auto Delete Bot Reply -->
              <div class="edit-field">
                <div class="edit-toggle-row">
                  <span class="edit-toggle-label"><%= lang === 'ar' ? 'حذف رد البوت عند حذف الرسالة' : "Auto Delete Bot's Reply on Deletion" %></span>
                  <label class="sw-wrap">
                    <input type="checkbox" class="sw-input" data-field="autoDeleteReply">
                    <span class="sw-track"><span class="sw-thumb"></span></span>
                  </label>
