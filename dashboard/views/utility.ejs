            </div><!-- /edit-grid -->
          </div><!-- /cmd-edit-panel -->
        </div><!-- /cmd-row -->
        <% }); %>

        <% if (!acts.length) { %>
        <div style="padding:48px 20px; text-align:center; color:var(--muted); font-size:.88rem;">
          <%= lang === 'ar' ? 'لا توجد أوامر عامة.' : 'No public commands found.' %>
