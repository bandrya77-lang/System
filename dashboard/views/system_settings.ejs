        <p><%= lang === 'ar' ? 'اختر ماذا تريد أن يحدث بعد مغادرة البوت:' : 'Choose what happens after the bot leaves:' %></p>
        <div class="modal-options">
          <label class="modal-option selected" id="opt-keep">
