        <div class="toggle-row">
          <div class="toggle-label">
            <span><%= lang === 'ar' ? 'السماح بأي سيرفر' : 'Allow Any Server' %></span>
            <small><%= lang === 'ar' ? 'البوت يمكن أن يكون في أي سيرفر دون قيود' : 'Bot can join any server without restrictions' %></small>
