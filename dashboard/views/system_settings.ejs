              <i data-lucide="eye" style="width:16px;height:16px;stroke:currentColor;"></i>
            </button>
          </div>
        </div>

        <div class="card-actions">
          <button class="save-btn primary" id="save-config-btn">
            <i data-lucide="save" style="width:15px;height:15px;stroke:currentColor;"></i>
            <%= lang === 'ar' ? 'حفظ' : 'Save' %>
          </button>
        </div>
      </div>

      <!-- Card 2: Servers Control -->
      <div class="content-card config-card">
        <div class="config-card-header">
          <div class="content-card-icon">
            <i data-lucide="server" style="width:22px;height:22px;stroke:currentColor;"></i>
