  <!-- Toast -->
  <div class="sys-toast" id="sys-toast"></div>

  <!-- Lucide -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <!-- Three.js stars background -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  <script>
    /* ── Stars background ── */
    (function() {
      const canvas = document.getElementById('c');
      if (!canvas || typeof THREE === 'undefined') return;
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false });
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      renderer.setSize(innerWidth, innerHeight);
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(60, innerWidth / innerHeight, 0.1, 2000);
      camera.position.z = 600;
      const geo = new THREE.BufferGeometry();
      const N = 1800;
      const pos = new Float32Array(N * 3);
      for (let i = 0; i < N * 3; i++) pos[i] = (Math.random() - 0.5) * 2000;
      geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      scene.add(new THREE.Points(geo, new THREE.PointsMaterial({ color: 0xffffff, size: 1.1, transparent: true, opacity: 0.55 })));
      window.addEventListener('resize', () => { renderer.setSize(innerWidth, innerHeight); camera.aspect = innerWidth / innerHeight; camera.updateProjectionMatrix(); });
      (function animate() { requestAnimationFrame(animate); scene.rotation.y += 0.00015; renderer.render(scene, camera); })();
    })();

    /* ── Lucide ── */
    lucide.createIcons();

    /* ── Dashboard config ── */
    const toggleCodeAccess = document.getElementById('toggle-code-access');
    const codeRow = document.getElementById('code-row');
    toggleCodeAccess.addEventListener('change', () => {
      codeRow.classList.toggle('hidden', !toggleCodeAccess.checked);
    });

    const codeInput = document.getElementById('code-input');
    const codeToggleVis = document.getElementById('code-toggle-vis');
    codeToggleVis.addEventListener('click', () => {
      const isPass = codeInput.type === 'password';
      codeInput.type = isPass ? 'text' : 'password';
      const iconEl = codeToggleVis.querySelector('i[data-lucide]');
      iconEl.setAttribute('data-lucide', isPass ? 'eye-off' : 'eye');
      lucide.createIcons();
    });

    function showSysToast(msg, type) {
      const el = document.getElementById('sys-toast');
      el.className = 'sys-toast ' + (type || 'success');
      el.innerHTML = '<i data-lucide="' + (type === 'error' ? 'x-circle' : 'check-circle') + '" style="width:16px;height:16px;stroke:currentColor;"></i> ' + msg;
      lucide.createIcons();
      el.classList.add('show');
      clearTimeout(el._to);
      el._to = setTimeout(() => el.classList.remove('show'), 3000);
    }

    document.getElementById('save-config-btn').addEventListener('click', async () => {
      const btn = document.getElementById('save-config-btn');
      btn.disabled = true;
      btn.innerHTML = '<i data-lucide="loader-2" style="width:15px;height:15px;stroke:currentColor;animation:spin 1s linear infinite;"></i> <%= lang === "ar" ? "جارٍ الحفظ..." : "Saving..." %>';
      lucide.createIcons();
      try {
        const r = await fetch('/settings/dashboard-config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            INTRO:       document.getElementById('toggle-intro').checked,
            CODE_ACCESS: toggleCodeAccess.checked,
            CODE:        codeInput.value.trim(),
          }),
        });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || 'Failed');
        showSysToast('<%= lang === "ar" ? "تم الحفظ بنجاح ✓" : "Saved successfully ✓" %>', 'success');
      } catch (e) {
        showSysToast(e.message, 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="save" style="width:15px;height:15px;stroke:currentColor;"></i> <%= lang === "ar" ? "حفظ" : "Save" %>';
        lucide.createIcons();
      }
    });

    /* ── Servers config ── */
    const toggleAddOnMany   = document.getElementById('toggle-add-on-many');
    const leaveAutoRow      = document.getElementById('leave-auto-row');
    const restrictedSection = document.getElementById('restricted-section');

    function syncServersUI() {
      const many = toggleAddOnMany.checked;
      leaveAutoRow.classList.toggle('dimmed', many);
      if (many) document.getElementById('toggle-leave-auto').checked = false;
    }
    toggleAddOnMany.addEventListener('change', syncServersUI);
    syncServersUI();

    // Tag input for SERVER_ALLOWED
    const tagsWrap = document.getElementById('tags-wrap');
    const tagsInput = document.getElementById('tags-input');
    function getAllowedIds() {
      return [...tagsWrap.querySelectorAll('.tag-item')].map(t => t.dataset.id);
    }
    function addTag(id) {
      id = id.trim().replace(/[^0-9]/g, '');
      if (!id || id.length < 15) return;   // Discord snowflakes: 15-19 digits
      if (tagsWrap.querySelector(`[data-id="${id}"]`)) return;
      const span = document.createElement('span');
      span.className = 'tag-item';
      span.dataset.id = id;
      span.innerHTML = `${id}<button type="button" class="tag-rm" data-remove="${id}" aria-label="Remove">&#x2715;</button>`;
      span.querySelector('.tag-rm').addEventListener('click', () => span.remove());
      tagsWrap.insertBefore(span, tagsInput);
      tagsInput.value = '';
    }
    tagsInput.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ',') { e.preventDefault(); addTag(tagsInput.value); }
      if (e.key === 'Backspace' && !tagsInput.value) { const last = tagsWrap.querySelector('.tag-item:last-of-type'); if (last) last.remove(); }
    });
    tagsInput.addEventListener('paste', e => {
      e.preventDefault();
      const text = (e.clipboardData || window.clipboardData).getData('text');
      text.split(/[,\s\n]+/).forEach(id => addTag(id));
    });
    tagsWrap.addEventListener('click', e => {
      const btn = e.target.closest('[data-remove]');
      if (btn) { btn.closest('.tag-item').remove(); }
      else { tagsInput.focus(); }
    });

    document.getElementById('save-servers-btn').addEventListener('click', async () => {
      const btn = document.getElementById('save-servers-btn');
      btn.disabled = true;
      btn.innerHTML = '<i data-lucide="loader-2" style="width:15px;height:15px;stroke:currentColor;animation:spin 1s linear infinite;"></i> <%= lang === "ar" ? "جارٍ الحفظ..." : "Saving..." %>';
      lucide.createIcons();
      try {
        const r = await fetch('/settings/dashboard-config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            INTRO:                 document.getElementById('toggle-intro').checked,
            CODE_ACCESS:           document.getElementById('toggle-code-access').checked,
            CODE:                  document.getElementById('code-input').value.trim(),
            ADD_BOT_ON_MANY_SERVER: toggleAddOnMany.checked,
            LEAVE_AUTO:            document.getElementById('toggle-leave-auto').checked,
            SERVER_ALLOWED:        getAllowedIds(),
          }),
        });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || 'Failed');
        if (data.serversCfg) {
          document.getElementById('toggle-leave-auto').checked = data.serversCfg.LEAVE_AUTO;
          syncServersUI();
        }
        showSysToast('<%= lang === "ar" ? "تم الحفظ بنجاح ✓" : "Saved successfully ✓" %>', 'success');
      } catch (e) {
        showSysToast(e.message, 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="save" style="width:15px;height:15px;stroke:currentColor;"></i> <%= lang === "ar" ? "حفظ" : "Save" %>';
        lucide.createIcons();
      }
    });

    /* ── Guild list ── */
    let leaveTargetGuild = null;

    function renderGuildRow(g) {
      const iconHtml = g.icon
        ? `<img class="guild-row-icon" src="${g.icon}" alt="${g.name}" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"><div class="guild-row-icon-fallback" style="display:none">${g.name.charAt(0).toUpperCase()}</div>`
        : `<div class="guild-row-icon-fallback">${g.name.charAt(0).toUpperCase()}</div>`;
      const allowedBadge = g.inAllowed ? ' <span class="badge-allowed"><%= lang === "ar" ? "✓ مسموح" : "✓ Allowed" %></span>' : '';
      const div = document.createElement('div');
      div.className = 'guild-row';
      div.dataset.id = g.id;
      div.innerHTML = `
        ${iconHtml}
        <div class="guild-row-info">
          <div class="guild-row-name">${g.name}${allowedBadge}</div>
          <div class="guild-row-meta">
            <span><i data-lucide="users" style="width:11px;height:11px;stroke:currentColor;"></i> ${g.memberCount.toLocaleString()}</span>
            <span><i data-lucide="crown" style="width:11px;height:11px;stroke:currentColor;"></i> ${g.ownerTag}</span>
            <span style="font-family:monospace;font-size:.7rem;">${g.id}</span>
          </div>
        </div>
        <div class="guild-row-actions">
          <button class="btn-leave" data-guild-id="${g.id}">
            <i data-lucide="log-out" style="width:13px;height:13px;stroke:currentColor;"></i>
            <%= lang === "ar" ? "مغادرة" : "Leave" %>
          </button>
        </div>`;
      div.querySelector('.btn-leave').addEventListener('click', () => openLeaveModal(g));
      return div;
    }

    async function loadGuilds() {
      const list = document.getElementById('guild-list');
      const countEl = document.getElementById('guilds-count');
      try {
        const r = await fetch('/settings/bot-guilds');
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || 'Failed');
        list.innerHTML = '';
        countEl.textContent = data.guilds.length;
        if (data.guilds.length === 0) {
          list.innerHTML = '<div class="guilds-empty"><%= lang === "ar" ? "البوت غير متواجد في أي سيرفر" : "Bot is not in any server" %></div>';
          return;
        }
        data.guilds.forEach(g => list.appendChild(renderGuildRow(g)));
        lucide.createIcons();
      } catch (e) {
        list.innerHTML = `<div class="guilds-empty" style="color:#fca5a5">${e.message}</div>`;
      }
    }
    loadGuilds();

    /* ── Leave modal ── */
    const leaveModal = document.getElementById('leave-modal');

    function openLeaveModal(g) {
      leaveTargetGuild = g;
      document.getElementById('modal-guild-name').textContent = g.name;
      const iconWrap = document.getElementById('modal-guild-icon-wrap');
      iconWrap.innerHTML = g.icon
        ? `<img class="modal-guild-icon" src="${g.icon}" alt="${g.name}" />`
        : `<div class="modal-guild-icon-fallback">${g.name.charAt(0).toUpperCase()}</div>`;
      // reset selection
      document.querySelector('input[name="leave-mode"][value="keep"]').checked = true;
      document.getElementById('opt-keep').classList.add('selected');
      document.getElementById('opt-delete').classList.remove('selected');
      leaveModal.classList.add('open');
    }
    function closeLeaveModal() { leaveModal.classList.remove('open'); leaveTargetGuild = null; }

    document.getElementById('modal-cancel').addEventListener('click', closeLeaveModal);
    leaveModal.addEventListener('click', e => { if (e.target === leaveModal) closeLeaveModal(); });

    document.querySelectorAll('.modal-option').forEach(opt => {
      opt.addEventListener('click', () => {
        document.querySelectorAll('.modal-option').forEach(o => o.classList.remove('selected'));
        opt.classList.add('selected');
        opt.querySelector('input[type="radio"]').checked = true;
      });
    });

    document.getElementById('modal-confirm').addEventListener('click', async () => {
      if (!leaveTargetGuild) return;
      const btn = document.getElementById('modal-confirm');
      const deleteData = document.querySelector('input[name="leave-mode"]:checked').value === 'delete';
      btn.disabled = true;
      btn.innerHTML = '<i data-lucide="loader-2" style="width:14px;height:14px;stroke:currentColor;animation:spin 1s linear infinite;"></i> <%= lang === "ar" ? "جارٍ..." : "Leaving..." %>';
      lucide.createIcons();
      try {
        const r = await fetch('/settings/guild-leave', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ guildId: leaveTargetGuild.id, deleteData }),
        });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || 'Failed');
        // Remove the row
        document.querySelector(`.guild-row[data-id="${leaveTargetGuild.id}"]`)?.remove();
        const remaining = document.querySelectorAll('.guild-row').length;
        document.getElementById('guilds-count').textContent = remaining;
        closeLeaveModal();
        showSysToast(
          '<%= lang === "ar" ? "غادر البوت السيرفر" : "Bot left the server" %>' + (deleteData ? ' <%= lang === "ar" ? "وتم حذف الداتا" : "and data deleted" %>' : ''),
          'success'
        );
      } catch (e) {
        showSysToast(e.message, 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="log-out" style="width:14px;height:14px;stroke:currentColor;"></i> <%= lang === "ar" ? "تأكيد المغادرة" : "Confirm Leave" %>';
        lucide.createIcons();
      }
    });

    /* ── Webhook card JS ── */
    const _whColorSwatches = [
      '#7c3aed','#06b6d4','#22c55e','#ef4444','#f59e0b','#ec4899','#ffffff','#1e293b'
    ];
    const whUrlInp   = document.getElementById('wh-url-inp');
    const whColorInp = document.getElementById('wh-color-inp');
    const whDot      = document.getElementById('wh-status-dot');
    const whTestBtn  = document.getElementById('wh-test-btn');

    // Sync status dot + test btn with URL field
    whUrlInp.addEventListener('input', () => {
      const hasUrl = !!whUrlInp.value.trim();
      whDot.classList.toggle('active', hasUrl);
      whTestBtn.disabled = !hasUrl;
      const clearBtn = document.getElementById('wh-clear-btn');
      if (clearBtn) { if (hasUrl) clearBtn.removeAttribute('hidden'); else clearBtn.setAttribute('hidden',''); }
    });

    // Clear webhook URL button
    const whClearBtn = document.getElementById('wh-clear-btn');
    if (whClearBtn) {
      whClearBtn.addEventListener('click', () => {
        whUrlInp.value = '';
        whUrlInp.dispatchEvent(new Event('input'));
        whUrlInp.focus();
      });
    }

    // Swatches — init background from data-color
    document.querySelectorAll('#wh-swatch-row .color-swatch').forEach(sw => {
      sw.style.background = sw.dataset.color;
      sw.addEventListener('click', () => {
        document.querySelectorAll('#wh-swatch-row .color-swatch').forEach(s => s.classList.remove('selected'));
        sw.classList.add('selected');
        whColorInp.value = sw.dataset.color;
      });
    });
    whColorInp.addEventListener('input', () => {
      document.querySelectorAll('#wh-swatch-row .color-swatch').forEach(s => {
        s.classList.toggle('selected', s.dataset.color.toLowerCase() === whColorInp.value.toLowerCase());
      });
    });

    async function _saveWebhook(test) {
      const btn = test ? whTestBtn : document.getElementById('save-wh-btn');
      btn.disabled = true;
      const origHtml = btn.innerHTML;
      btn.innerHTML = '<i data-lucide="loader-2" style="width:13px;height:13px;stroke:currentColor;animation:spin 1s linear infinite;"></i>';
      lucide.createIcons();
      try {
        const r = await fetch('/settings/webhook-config', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ URL: whUrlInp.value.trim(), COLOR: whColorInp.value, test: !!test }),
        });
        const data = await r.json();
        if (!r.ok) throw new Error(data.error || 'Failed');
        showSysToast(
          test
            ? ('<%= lang === "ar" ? "تم إرسال رسالة تجريبية ✓" : "Test message sent ✓" %>')
            : ('<%= lang === "ar" ? "تم حفظ Webhook ✓" : "Webhook saved ✓" %>'),
          'success'
        );
      } catch (e) { showSysToast(e.message, 'error'); }
      finally { btn.disabled = !whUrlInp.value.trim() && test; btn.innerHTML = origHtml; lucide.createIcons(); }
    }

    document.getElementById('save-wh-btn').addEventListener('click', () => _saveWebhook(false));
    whTestBtn.addEventListener('click',                                   () => _saveWebhook(true));

    /* ── Logs card ── */
    const _logLang = '<%= lang %>';
    let _logData = { entries: [], clearRequest: null, ships: [] };
    let _logFilter = 'all';
    const _meId = '<%= user.id %>';

    function _timeAgo(iso) {
      const diff = Date.now() - new Date(iso).getTime();
      const s = Math.floor(diff / 1000);
      if (s < 60)  return _logLang === 'ar' ? `منذ ${s}ث`  : `${s}s ago`;
      const m = Math.floor(s / 60);
      if (m < 60)  return _logLang === 'ar' ? `منذ ${m}د`  : `${m}m ago`;
      const h = Math.floor(m / 60);
      if (h < 24)  return _logLang === 'ar' ? `منذ ${h}س`  : `${h}h ago`;
      const d = Math.floor(h / 24);
      return _logLang === 'ar' ? `منذ ${d} يوم` : `${d}d ago`;
    }

    function _renderLogEntry(e) {
      const div = document.createElement('div');
      div.className = 'log-entry';
      let iconHtml = '', title = '', sub = '';
      if (e.type === 'login') {
        const av = e.avatar
          ? `<img src="https://cdn.discordapp.com/avatars/${e.userId}/${e.avatar}.png?size=40" alt="" onerror="this.parentElement.className='log-entry-icon log-icon-login';this.remove();" />`
          : `<i data-lucide="user" style="width:16px;height:16px;stroke:currentColor;"></i>`;
        iconHtml  = `<div class="log-entry-icon log-icon-login">${av}</div>`;
        const _name = e.displayName || e.username || e.userId;
        title     = `<span class="log-entry-title-name">${_name}</span><span class="log-entry-title-id">${e.userId || ''}</span>`;
        sub       = _logLang === 'ar' ? `سجّل دخوله إلى الداشبورد` : `Logged in to the dashboard`;
      } else if (e.type === 'guild_join') {
        const gIco = e.guildIcon
          ? `<img src="${e.guildIcon}" alt="" onerror="this.parentElement.className='log-entry-icon log-icon-join';this.remove();" />`
          : `<i data-lucide="server" style="width:16px;height:16px;stroke:currentColor;"></i>`;
        iconHtml  = `<div class="log-entry-icon log-icon-join">${gIco}</div>`;
        title     = `<span class="log-entry-title-name">${e.guildName || e.guildId}</span><span class="log-entry-title-id">${e.guildId || ''}</span>`;
        sub       = _logLang === 'ar' ? `تمت إضافة البوت لهذا السيرفر` : `Bot was added to this server`;
      } else if (e.type === 'guild_leave') {
        const glIco = e.guildIcon
          ? `<img src="${e.guildIcon}" alt="" onerror="this.parentElement.className='log-entry-icon log-icon-leave';this.remove();" />`
          : `<i data-lucide="log-out" style="width:16px;height:16px;stroke:currentColor;"></i>`;
        iconHtml  = `<div class="log-entry-icon log-icon-leave">${glIco}</div>`;
        title     = `<span class="log-entry-title-name">${e.guildName || e.guildId}</span><span class="log-entry-title-id">${e.guildId || ''}</span>`;
        const who  = e.byUsername ? (e.byUsername) : '';
        const del  = e.deleteData ? (_logLang === 'ar' ? ' · حُذفت الداتا' : ' · data deleted') : '';
        sub       = (_logLang === 'ar' ? `البوت غادر السيرفر` : `Bot left server`) + (who ? ` (${who})` : '') + del;
      } else {
        iconHtml  = `<div class="log-entry-icon log-icon-other"><i data-lucide="zap" style="width:16px;height:16px;stroke:currentColor;"></i></div>`;
        title     = e.type || 'event';
        sub       = JSON.stringify(e).substring(0, 80);
      }
      div.innerHTML = `${iconHtml}<div class="log-entry-body"><div class="log-entry-title">${title}</div><div class="log-entry-sub">${sub}</div></div><div class="log-entry-time">${_timeAgo(e.timestamp)}</div>${e.type === 'login' ? `<button class="log-dots-btn" title="${_logLang === 'ar' ? 'معلومات' : 'Info'}"><i data-lucide="more-vertical" style="width:14px;height:14px;stroke:currentColor;"></i></button>` : ''}`;
      if (e.type === 'login') {
        const dotsBtn = div.querySelector('.log-dots-btn');
        if (dotsBtn) dotsBtn.addEventListener('click', ev => { ev.stopPropagation(); openGeoModal(e); });
      }
      return div;
    }

    function _renderLogs() {
      const list = document.getElementById('log-list');
      const label = document.getElementById('log-count-label');
      list.innerHTML = '';
      const filtered = _logFilter === 'all' ? _logData.entries : _logData.entries.filter(e => e.type === _logFilter);
      filtered.forEach(e => list.appendChild(_renderLogEntry(e)));
      lucide.createIcons();
      const total = _logData.entries.length;
      const shown = filtered.length;
      label.textContent = _logLang === 'ar' ? `${shown} من ${total} سجل` : `${shown} of ${total} entries`;
    }

    function _renderClearBanner() {
      const banner    = document.getElementById('crb');
      const titleEl   = document.getElementById('crb-title-text');
      const bodyEl    = document.getElementById('crb-body');
      const votesEl   = document.getElementById('crb-votes');
      const actionsEl = document.getElementById('crb-actions');
      const cr = _logData.clearRequest;
      if (!cr) { banner.classList.remove('show'); return; }
      banner.classList.add('show');
      titleEl.textContent = _logLang === 'ar'
        ? `طلب مسح السجلات من ${cr.requestedByName}`
        : `Log clear requested by ${cr.requestedByName}`;
      const allNeeded = [cr.requestedBy, ...cr.needed];
      bodyEl.textContent = _logLang === 'ar'
        ? `يتطلب موافقة جميع الـ Ships (${allNeeded.length}). لو رفض طرف واحد، تُلغى العملية.`
        : `Requires approval from all Ships (${allNeeded.length}). If anyone rejects, the request is cancelled.`;
      // Votes chips
      votesEl.innerHTML = allNeeded.map(id => {
        const name = (id === cr.requestedBy ? cr.requestedByName : id);
        const status = cr.approvals.includes(id) ? 'approved' : cr.rejections.includes(id) ? 'rejected' : 'pending';
        const icon  = status === 'approved' ? '✓' : status === 'rejected' ? '✗' : '⏳';
        return `<span class="crb-vote-chip ${status}">${icon} ${name}</span>`;
      }).join('');
      // Actions
      actionsEl.innerHTML = '';
      const myVoted = cr.approvals.includes(_meId) || cr.rejections.includes(_meId);
      if (!myVoted) {
        const appBtn = document.createElement('button'); appBtn.className = 'crb-btn-approve';
        appBtn.textContent = _logLang === 'ar' ? '✓ موافقة' : '✓ Approve';
        appBtn.onclick = () => _voteLogClear(true);
        const rejBtn = document.createElement('button'); rejBtn.className = 'crb-btn-reject';
        rejBtn.textContent = _logLang === 'ar' ? '✗ رفض' : '✗ Reject';
        rejBtn.onclick = () => _voteLogClear(false);
        actionsEl.appendChild(appBtn); actionsEl.appendChild(rejBtn);
      }
      if (cr.requestedBy === _meId) {
        const canBtn = document.createElement('button'); canBtn.className = 'crb-btn-cancel';
        canBtn.textContent = _logLang === 'ar' ? 'إلغاء الطلب' : 'Cancel Request';
        canBtn.onclick = _cancelLogClear;
        actionsEl.appendChild(canBtn);
      }
    }

    async function loadLogs() {
      try {
        const r = await fetch('/settings/logs');
        if (!r.ok) return;
        _logData = await r.json();
        _renderLogs();
        _renderClearBanner();
        document.getElementById('log-clear-btn').disabled = !!_logData.clearRequest;
      } catch (_) {}
    }
    loadLogs();

    document.querySelectorAll('.log-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.log-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        _logFilter = btn.dataset.type;
        _renderLogs();
      });
    });

    document.getElementById('log-refresh-btn').addEventListener('click', loadLogs);

    document.getElementById('log-clear-btn').addEventListener('click', async () => {
      const btn = document.getElementById('log-clear-btn');
      if (btn.disabled) return;
      btn.disabled = true;
      try {
        const r = await fetch('/settings/logs/clear-request', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await r.json();
        if (!r.ok) {
          if (data.error === 'already_pending') { _logData.clearRequest = data.clearRequest; _renderClearBanner(); return; }
          showSysToast(data.error || 'Failed', 'error'); return;
        }
        _logData.clearRequest = data.clearRequest;
        _renderClearBanner();
        showSysToast(_logLang === 'ar' ? 'تم إرسال طلب المسح — بانتظار موافقة الفريق' : 'Clear request sent — awaiting team approval', 'success');
      } catch (e) { showSysToast(e.message, 'error'); btn.disabled = false; }
    });

    async function _voteLogClear(approve) {
      try {
        const r = await fetch('/settings/logs/clear-vote', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ approve }),
        });
        const data = await r.json();
        if (!r.ok) { showSysToast(data.error || 'Failed', 'error'); return; }
        if (data.cleared) {
          _logData.entries = []; _logData.clearRequest = null;
          _renderLogs(); _renderClearBanner();
          document.getElementById('log-clear-btn').disabled = false;
          showSysToast(_logLang === 'ar' ? '✓ تم مسح السجلات' : '✓ Logs cleared', 'success');
        } else if (data.rejected) {
          _logData.clearRequest = null; _renderClearBanner();
          document.getElementById('log-clear-btn').disabled = false;
          showSysToast(_logLang === 'ar' ? 'تم رفض طلب المسح' : 'Clear request was rejected', 'error');
        } else {
          _logData.clearRequest = data.pending; _renderClearBanner();
          showSysToast(_logLang === 'ar' ? 'تمت موافقتك — بانتظار الباقين' : 'Your vote recorded — awaiting others', 'success');
        }
      } catch (e) { showSysToast(e.message,'error'); }
    }

    async function _cancelLogClear() {
      try {
        const r = await fetch('/settings/logs/clear-cancel', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await r.json();
        if (!r.ok) { showSysToast(data.error || 'Failed', 'error'); return; }
        _logData.clearRequest = null; _renderClearBanner();
        document.getElementById('log-clear-btn').disabled = false;
        showSysToast(_logLang === 'ar' ? 'تم إلغاء طلب المسح' : 'Clear request cancelled', 'success');
      } catch (e) { showSysToast(e.message,'error'); }
    }

    /* ── Ships management ── */
    const _shipsLang = '<%= lang %>';

    function _renderShipsChips(ships) {
      const wrap = document.getElementById('ships-chips');
      wrap.innerHTML = '';
      (ships || []).forEach(sid => {
        const chip = document.createElement('div');
        chip.className = 'ships-chip';
        chip.dataset.id = sid;
        chip.innerHTML = `<span class="ships-chip-id">${sid}</span><button class="ships-chip-remove" data-uid="${sid}" title="Remove"><i data-lucide="x" style="width:10px;height:10px;stroke:currentColor;"></i></button>`;
        wrap.appendChild(chip);
      });
      lucide.createIcons();
      wrap.querySelectorAll('.ships-chip-remove').forEach(btn => {
        btn.addEventListener('click', () => removeShip(btn.dataset.uid));
      });
    }

    async function removeShip(uid) {
      if (!confirm(_shipsLang === 'ar' ? `إزالة ${uid} من Ships؟` : `Remove ${uid} from Ships?`)) return;
      try {
        const r = await fetch(`/settings/ships/${uid}`, { method: 'DELETE' });
        const d = await r.json();
        if (!r.ok) { showSysToast(d.error || 'Failed', 'error'); return; }
        _renderShipsChips(d.ships);
        showSysToast(_shipsLang === 'ar' ? 'تم الإزالة ✓' : 'Removed ✓', 'success');
      } catch (e) { showSysToast(e.message, 'error'); }
    }

    document.getElementById('ships-add-btn').addEventListener('click', async () => {
      const inp = document.getElementById('ships-add-inp');
      const uid = inp.value.trim();
      if (!uid || !/^\d{10,20}$/.test(uid)) {
        showSysToast(_shipsLang === 'ar' ? 'يرجى إدخال Discord ID صحيح' : 'Enter a valid Discord User ID', 'error'); return;
      }
      try {
        const r = await fetch('/settings/ships', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: uid }),
        });
        const d = await r.json();
        if (!r.ok) { showSysToast(d.error || 'Failed', 'error'); return; }
        _renderShipsChips(d.ships);
        inp.value = '';
        showSysToast(_shipsLang === 'ar' ? 'تمت الإضافة ✓' : 'Added ✓', 'success');
      } catch (e) { showSysToast(e.message, 'error'); }
    });
    document.getElementById('ships-add-inp').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('ships-add-btn').click(); });
    document.querySelectorAll('#ships-chips .ships-chip-remove').forEach(btn => {
      btn.addEventListener('click', () => removeShip(btn.dataset.uid));
    });

    /* ── Active Sessions ── */
    async function _loadSessions() {
      const list = document.getElementById('sess-list');
      list.innerHTML = `<div style="color:var(--muted);font-size:.78rem;padding:10px 0;text-align:center;"><i data-lucide="loader-2" style="width:14px;height:14px;stroke:currentColor;animation:spin 1s linear infinite;"></i></div>`;
      lucide.createIcons();
      try {
        const r = await fetch('/settings/active-sessions');
        const sessions = await r.json();
        list.innerHTML = '';
        if (!sessions.length) {
          list.innerHTML = `<div style="color:var(--muted);font-size:.78rem;padding:14px 0;text-align:center;">${_shipsLang === 'ar' ? 'لا توجد جلسات نشطة' : 'No active sessions'}</div>`;
          return;
        }
        sessions.forEach(s => {
          const row = document.createElement('div');
          row.className = 'sess-row' + (s.isSelf ? ' is-self' : '');
          const av = s.avatar
            ? `<img src="https://cdn.discordapp.com/avatars/${s.userId}/${s.avatar}.png?size=80" alt="" onerror="this.style.display='none'" />`
            : `<i data-lucide="user" style="width:18px;height:18px;stroke:currentColor;"></i>`;
          const selfBadge = s.isSelf ? `<span class="sess-self-badge">${_shipsLang === 'ar' ? 'أنت' : 'You'}</span>` : '';
          const loginStr  = s.loginAt ? _timeAgo(s.loginAt) : '';
          row.innerHTML = `
            <div class="sess-avatar">${av}</div>
            <div class="sess-info">
              <div class="sess-name">${s.displayName || s.username || s.userId}<span class="sess-uid">${s.userId}</span>${selfBadge}</div>
              <div class="sess-meta">
                ${s.ip && s.ip !== 'unknown' ? `<span>🌐 <code style="font-size:.7rem;">${s.ip}</code></span>` : ''}
                ${loginStr ? `<span>🕒 ${loginStr}</span>` : ''}
              </div>
            </div>
            <button class="sess-kill-btn" data-sid="${s.sid}" ${s.isSelf ? 'disabled title="Cannot kill own session"' : `title="${_shipsLang === 'ar' ? 'إنهاء الجلسة' : 'End session'}"`}>
              <i data-lucide="log-out" style="width:13px;height:13px;stroke:currentColor;"></i>
              ${_shipsLang === 'ar' ? 'إنهاء' : 'End'}
            </button>`;
          list.appendChild(row);
        });
        lucide.createIcons();
        list.querySelectorAll('.sess-kill-btn:not(:disabled)').forEach(btn => {
          btn.addEventListener('click', async () => {
            if (!confirm(_shipsLang === 'ar' ? 'إنهاء هذه الجلسة؟' : 'End this session?')) return;
            btn.disabled = true;
            const r = await fetch(`/settings/active-sessions/${btn.dataset.sid}`, { method: 'DELETE' });
            const d = await r.json();
            if (!r.ok) { showSysToast(d.error || 'Failed', 'error'); btn.disabled = false; return; }
            showSysToast(_shipsLang === 'ar' ? 'تم إنهاء الجلسة ✓' : 'Session ended ✓', 'success');
            _loadSessions();
          });
        });
      } catch (e) { list.innerHTML = `<div style="color:#fca5a5;font-size:.78rem;">${e.message}</div>`; }
    }
    document.getElementById('sess-refresh-btn').addEventListener('click', _loadSessions);
    _loadSessions();

    /* ── Geo modal ── */
    function openGeoModal(entry) {
      const backdrop = document.getElementById('geo-modal-backdrop');
      const avEl  = document.getElementById('geo-av');
      avEl.innerHTML = entry.avatar
        ? `<img src="https://cdn.discordapp.com/avatars/${entry.userId}/${entry.avatar}.png?size=80" alt=""/>`
        : `<i data-lucide="user" style="width:22px;height:22px;stroke:currentColor;"></i>`;
      document.getElementById('geo-name').textContent  = entry.displayName || entry.username || '—';
      document.getElementById('geo-uname').textContent = entry.username ? `@${entry.username}` : '—';
      document.getElementById('geo-uid').textContent   = entry.userId || '—';
      document.getElementById('geo-fields').innerHTML  = `<div class="geo-field full" style="text-align:center;color:var(--muted);font-size:.8rem;"><i data-lucide="loader-2" style="width:16px;height:16px;stroke:currentColor;animation:spin 1s linear infinite;"></i></div>`;
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
      lucide.createIcons();
      if (entry.ip && entry.ip !== 'unknown' && entry.ip !== 'test') {
        fetch(`/settings/geo?ip=${encodeURIComponent(entry.ip)}`).then(r => r.json()).then(geo => {
          const fields   = document.getElementById('geo-fields');
          const ipField  = `<div class="geo-field full"><div class="geo-field-label">${_shipsLang === 'ar' ? 'عنوان IP' : 'IP Address'}</div><div class="geo-field-value mono">${entry.ip}</div></div>`;
          if (!geo) {
            fields.innerHTML = ipField + `<div class="geo-field full"><div class="geo-field-label">${_shipsLang === 'ar' ? 'الموقع' : 'Location'}</div><div class="geo-field-value" style="color:var(--muted);">${_shipsLang === 'ar' ? 'غير متاح (IP محلي أو خاص)' : 'Not available (local/private IP)'}</div></div>`;
          } else {
            fields.innerHTML = ipField +
              `<div class="geo-field"><div class="geo-field-label">${_shipsLang === 'ar' ? 'الدولة' : 'Country'}</div><div class="geo-field-value">${geo.country || '—'}</div></div>` +
              `<div class="geo-field"><div class="geo-field-label">${_shipsLang === 'ar' ? 'المنطقة' : 'Region'}</div><div class="geo-field-value">${geo.region ? geo.region + (geo.city ? ` / ${geo.city}` : '') : '—'}</div></div>` +
              `<div class="geo-field"><div class="geo-field-label">${_shipsLang === 'ar' ? 'المنطقة الزمنية' : 'Timezone'}</div><div class="geo-field-value">${geo.timezone || '—'}</div></div>` +
              `<div class="geo-field"><div class="geo-field-label">${_shipsLang === 'ar' ? 'مزود الخدمة' : 'ISP/Org'}</div><div class="geo-field-value">${geo.org || '—'}</div></div>` +
              (geo.ll ? `<div class="geo-field full"><div class="geo-field-label">${_shipsLang === 'ar' ? 'الإحداثيات' : 'Coordinates'}</div><div class="geo-field-value mono">${geo.ll[0]}, ${geo.ll[1]}</div></div>` : '');
          }
          lucide.createIcons();
        }).catch(() => {});
      } else {
        document.getElementById('geo-fields').innerHTML = `<div class="geo-field full"><div class="geo-field-label">IP</div><div class="geo-field-value mono">${entry.ip || '—'}</div></div><div class="geo-field full" style="color:var(--muted);font-size:.78rem;">${_shipsLang === 'ar' ? 'لا يوجد IP محفوظ للبحث الجغرافي' : 'No IP recorded for geo lookup'}</div>`;
        lucide.createIcons();
      }
    }
    function closeGeoModal() {
      document.getElementById('geo-modal-backdrop').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('geo-close-btn').addEventListener('click', closeGeoModal);
    document.getElementById('geo-modal-backdrop').addEventListener('click', e => { if (e.target === e.currentTarget) closeGeoModal(); });

    /* ── Profile sidebar ── */
    const bannerSolid = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;

    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn      = document.getElementById('open-profile');
    const closeBtn     = document.getElementById('close-profile');
    const copyId       = document.getElementById('prof-copy-id');

    function openProfile()  { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow = 'hidden'; }
    function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow = ''; }

    openBtn.addEventListener('click', openProfile);
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });

    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '<%= lang === "ar" ? "✓ تم النسخ" : "✓ Copied!" %>';
          copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }

    /* ── Lang select ── */
    document.getElementById('lang-select').addEventListener('change', function() {
      const u = new URL(window.location.href);
      u.searchParams.set('lang', this.value);
      window.location.href = u.toString();
    });
  </script>
</body>
</html>

