          <button class="mgmt-section-btn open">
            <span><%= lang === 'ar' ? 'الحماية' : 'Protection' %></span>
            <svg class="mgmt-sec-chevron" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 18 18"><path d="M9.53,4.72c-.293-.293-.768-.293-1.061,0L2.22,10.97c-.293,.293-.293,.768,0,1.061s.768,.293,1.061,0l5.72-5.72,5.72,5.72c.146,.146,.338,.22,.53,.22s.384-.073,.53-.22c.293-.293,.293-.768,0-1.061l-6.25-6.25Z" fill="currentColor"/></svg>
          </button>
          <div class="mgmt-sec-body open">
            <a href="/dashboard/<%= guildId %>/protection" class="mgmt-item nav-link">
              <div class="mgmt-item-indicator"></div>
              <div class="mgmt-item-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 18 18"><path d="M9 1L2 4.5V9c0 4.418 3.083 8.572 7 9.5 3.917-.928 7-5.082 7-9.5V4.5L9 1z" fill="currentColor" fill-opacity="0.4"/><path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 7.5l2.5 2.5 3.5-3.5 1 1-4.5 4.5-3.5-3.5 1-1z" fill="currentColor"/></svg>
              </div>
              <span class="mgmt-item-label"><%= lang === 'ar' ? 'الأمان' : 'Security' %></span>
            </a>
          </div>
        </div>

        <!-- ── Section: Members ── -->
        <div class="mgmt-section">
          <button class="mgmt-section-btn open">
            <span><%= lang === 'ar' ? 'الأعضاء' : 'Members' %></span>
            <svg class="mgmt-sec-chevron" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 18 18"><path d="M9.53,4.72c-.293-.293-.768-.293-1.061,0L2.22,10.97c-.293,.293-.293,.768,0,1.061s.768,.293,1.061,0l5.72-5.72,5.72,5.72c.146,.146,.338,.22,.53,.22s.384-.073,.53-.22c.293-.293,.293-.768,0-1.061l-6.25-6.25Z" fill="currentColor"/></svg>
          </button>
          <div class="mgmt-sec-body open">
            <a href="/dashboard/<%= guildId %>/auto-roles" class="mgmt-item nav-link">
              <div class="mgmt-item-indicator"></div>
              <div class="mgmt-item-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 18 18"><path d="M9 2a3.5 3.5 0 1 1 0 7 3.5 3.5 0 0 1 0-7zm0 9c4 0 6 2 6 3v1H3v-1c0-1 2-3 6-3z" fill="currentColor" fill-opacity="0.4"/><path d="M13.5 8a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5zm1.5 2c2 0 3 1 3 2v1h-3v-1c0-.6-.2-1.2-.5-1.7.3-.2.7-.3 1-.3l-.5.5z" fill="currentColor"/></svg>
              </div>
              <span class="mgmt-item-label"><%= lang === 'ar' ? 'الرتب التلقائية' : 'Auto Roles' %></span>
            </a>
          </div>
        </div>

        <!-- ── Section: Settings ── -->
        <div class="mgmt-section">
          <button class="mgmt-section-btn open">
            <span><%= lang === 'ar' ? 'الإعدادات' : 'Settings' %></span>
            <svg class="mgmt-sec-chevron" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 18 18"><path d="M9.53,4.72c-.293-.293-.768-.293-1.061,0L2.22,10.97c-.293,.293-.293,.768,0,1.061s.768,.293,1.061,0l5.72-5.72,5.72,5.72c.146,.146,.338,.22,.53,.22s.384-.073,.53-.22c.293-.293,.293-.768,0-1.061l-6.25-6.25Z" fill="currentColor"/></svg>
          </button>
          <div class="mgmt-sec-body open">
            <a href="/dashboard/<%= guildId %>/setting" class="mgmt-item active nav-link">
              <div class="mgmt-item-indicator"></div>
              <div class="mgmt-item-icon"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 18 18"><path d="M9 11.5C10.3807 11.5 11.5 10.3807 11.5 9C11.5 7.6193 10.3807 6.5 9 6.5C7.6193 6.5 6.5 7.6193 6.5 9C6.5 10.3807 7.6193 11.5 9 11.5Z" fill="currentColor"/><path opacity="0.4" fill-rule="evenodd" clip-rule="evenodd" d="M7.6853 1.5H10.3147C10.7234 1.5 11.0941 1.7443 11.2629 2.1191L11.8071 3.3564C12.3536 3.5819 12.8668 3.8791 13.3352 4.237L14.6429 3.9095C15.0369 3.8108 15.4509 3.9764 15.6553 4.3295L16.9699 6.6705C17.1743 7.0235 17.1014 7.4708 16.7954 7.7392L15.7702 8.636C15.7899 8.757 15.8 8.876 15.8 9C15.8 9.124 15.7899 9.243 15.7702 9.364L16.7954 10.2608C17.1014 10.5292 17.1743 10.9765 16.9699 11.3295L15.6553 13.6705C15.4509 14.0236 15.0369 14.1892 14.6429 14.0905L13.3352 13.763C12.8668 14.1209 12.3536 14.4181 11.8071 14.6436L11.2629 15.8809C11.0941 16.2557 10.7234 16.5 10.3147 16.5H7.6853C7.2766 16.5 6.9059 16.2557 6.7371 15.8809L6.1929 14.6436C5.6464 14.4181 5.1332 14.1209 4.6648 13.763L3.3571 14.0905C2.9631 14.1892 2.5491 14.0236 2.3447 13.6705L1.0301 11.3295C0.8257 10.9765 0.8986 10.5292 1.2046 10.2608L2.2298 9.364C2.2101 9.243 2.2 9.124 2.2 9C2.2 8.876 2.2101 8.757 2.2298 8.636L1.2046 7.7392C0.8986 7.4708 0.8257 7.0235 1.0301 6.6705L2.3447 4.3295C2.5491 3.9764 2.9631 3.8108 3.3571 3.9095L4.6648 4.237C5.1332 3.8791 5.6464 3.5819 6.1929 3.3564L6.7371 2.1191C6.9059 1.7443 7.2766 1.5 7.6853 1.5Z" fill="currentColor"/></svg></div>
              <span class="mgmt-item-label"><%= lang === 'ar' ? 'الإعدادات' : 'Settings' %></span>
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom user bar -->
    <div class="mgmt-footer">
      <div class="mgmt-footer-user">
        <% if (user.avatar) { %>
          <img class="mgmt-footer-av" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64" alt="<%= user.displayName || user.username %>" />
        <% } else { %>
          <div class="mgmt-footer-av-fallback"><%= (user.displayName || user.username).charAt(0).toUpperCase() %></div>
        <% } %>
        <span class="mgmt-footer-name">@<%= user.username %></span>
      </div>
      <button class="mgmt-footer-dots" aria-label="User menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 18 18"><circle cx="9" cy="9" r="1.25" fill="currentColor"/><circle cx="3.25" cy="9" r="1.25" fill="currentColor"/><circle cx="14.75" cy="9" r="1.25" fill="currentColor"/></svg>
      </button>
    </div>
  </aside>

  <!-- Hidden file inputs -->
  <input type="file" id="avatar-file-input" accept="image/png,image/jpeg,image/webp,image/gif" style="display:none" />
  <input type="file" id="banner-file-input" accept="image/png,image/jpeg,image/webp" style="display:none" />

  <!-- ── Main Content ── -->
  <main class="main">
    <div class="page-header">
      <div>
        <h2><%= lang === 'ar' ? 'إعدادات البوت' : 'Bot Settings' %></h2>
        <p><%= lang === 'ar' ? 'تخصيص بروفيل البوت وإعدادات النظام' : 'Customize the bot profile and system settings' %></p>
      </div>
    </div>
    <div class="divider"></div>

    <!-- ══ Bot Profile Card ══ -->
    <div class="bot-profile-card">
      <!-- Banner -->
      <div class="bot-banner-area">
        <% if (botInfo && botInfo.banner) { %>
          <img class="bot-banner-img" id="bot-banner-preview" src="<%= botInfo.banner %>" alt="Bot Banner" />
        <% } else { %>
          <img class="bot-banner-img" id="bot-banner-preview" src="" alt="" style="display:none" />
        <% } %>
        <div class="bot-banner-overlay"></div>
        <button class="bot-banner-edit-btn" id="banner-edit-btn" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <%= lang === 'ar' ? 'تغيير البانر' : 'Change Banner' %>
        </button>
      </div>

      <div class="bot-profile-body">
        <!-- Avatar + status row -->
        <div class="bot-avatar-area">
          <div class="bot-avatar-wrap">
            <% if (botInfo && botInfo.avatar) { %>
              <img class="bot-avatar" id="bot-avatar-preview" src="<%= botInfo.avatar %>" alt="Bot Avatar" />
            <% } else { %>
              <div class="bot-avatar-fallback" id="bot-avatar-fallback"><%= (botInfo && botInfo.username) ? botInfo.username.charAt(0).toUpperCase() : 'B' %></div>
              <img class="bot-avatar" id="bot-avatar-preview" src="" alt="" style="display:none" />
            <% } %>
            <button class="bot-avatar-edit-trigger" id="avatar-edit-btn" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </button>
            <div class="bot-avatar-uploading" id="avatar-uploading">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
            </div>
          </div>
          <div class="bot-avatar-actions">
            <% const cmdSettings = (systemSettings && systemSettings.COMMANDS) ? systemSettings.COMMANDS : systemSettings || {}; %>
            <% const statusNow = (cmdSettings.STATUS || 'ONLINE').toLowerCase(); %>
            <span class="bot-status-badge <%= statusNow %>" id="status-badge">
              <span class="dot-status dot-<%= statusNow %>"></span>
              <%= cmdSettings.STATUS || 'ONLINE' %>
            </span>
          </div>
        </div>

        <!-- Bot name / ID -->
        <div class="bot-meta">
          <div class="bot-username-display" id="bot-username-display"><%= (botInfo && botInfo.username) ? botInfo.username : (lang === 'ar' ? 'البوت' : 'Bot') %></div>
          <div class="bot-id-row">
            <span class="bot-id-label">ID</span>
            <span class="bot-id-val" id="bot-id-copy" title="<%= lang === 'ar' ? 'انقر للنسخ' : 'Click to copy' %>"><%= (botInfo && botInfo.id) ? botInfo.id : '—' %></span>
          </div>
        </div>

        <div class="bot-profile-divider"></div>

        <!-- Username edit -->
        <div class="bot-username-edit-row">
          <label for="bot-username-input"><%= lang === 'ar' ? 'اسم البوت' : 'Username' %></label>
          <input type="text" id="bot-username-input" class="bot-username-input" value="<%= (botInfo && botInfo.username) ? botInfo.username : '' %>" maxlength="32" minlength="2" placeholder="<%= lang === 'ar' ? 'اسم البوت...' : 'Bot username...' %>" />
          <button class="btn btn-primary btn-sm" id="save-username-btn" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <%= lang === 'ar' ? 'حفظ' : 'Save' %>
          </button>
        </div>

        <!-- Description edit -->
        <div class="bot-desc-edit-row">
          <label for="bot-desc-input"><%= lang === 'ar' ? 'وصف البوت' : 'About Me / Description' %></label>
          <textarea
            id="bot-desc-input"
            class="bot-desc-textarea"
            maxlength="400"
            placeholder="<%= lang === 'ar' ? 'وصف البوت...' : 'Bot description...' %>"
          ><%= (botInfo && botInfo.description) ? botInfo.description : '' %></textarea>
          <div class="bot-desc-footer">
            <span id="bot-desc-counter" class="bot-desc-counter">0 / 400</span>
            <button class="btn btn-primary btn-sm" id="save-desc-btn" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
              <%= lang === 'ar' ? 'حفظ' : 'Save' %>
            </button>
          </div>
        </div>
      </div>
    </div>
    <div class="card card-mt">
      <div class="card-header">
        <div class="card-header-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </div>
        <h3><%= lang === 'ar' ? 'إعدادات الأوامر' : 'Command Settings' %></h3>
      </div>
      <div class="card-body">

        <!-- Enable Prefix -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= lang === 'ar' ? 'تفعيل أوامر البريفكس' : 'Enable Prefix Commands' %></label>
            <p class="form-help"><%= lang === 'ar' ? 'السماح باستخدام الأوامر عبر البريفكس (مثال: !help)' : 'Allow using commands with a prefix (e.g. !help)' %></p>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="enable-prefix" <%= (cmdSettings.ENABLE_PREFIX !== false) ? 'checked' : '' %> />
            <span class="toggle-slider"></span>
          </label>
        </div>

        <!-- Prefix Symbol -->
        <div class="form-row prefix-symbol-row <%= (cmdSettings.ENABLE_PREFIX === false) ? 'hidden' : '' %>" id="prefix-symbol-row">
          <div class="form-row-left">
            <label class="form-label"><%= lang === 'ar' ? 'رمز البريفكس' : 'Prefix Symbol' %></label>
            <p class="form-help"><%= lang === 'ar' ? 'اختر الرمز الذي يسبق الأوامر' : 'Choose the symbol that precedes commands' %></p>
          </div>
          <select id="prefix-symbol" class="form-select" style="width:80px;text-align:center;font-size:1.1rem;font-weight:700">
            <% ['!','#','$','%','&','?'].forEach(sym => { %>
              <option value="<%= sym %>" <%= (systemSettings.PREFIX || '!') === sym ? 'selected' : '' %>><%= sym %></option>
            <% }); %>
          </select>
        </div>

        <!-- Enable Slash Commands -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= lang === 'ar' ? 'تفعيل أوامر السلاش' : 'Enable Slash Commands' %></label>
            <p class="form-help"><%= lang === 'ar' ? 'السماح باستخدام أوامر السلاش (/)' : 'Allow using slash commands (/)' %></p>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" id="enable-slash" <%= (cmdSettings.ENABLE_SLASH_COMMANDS !== false) ? 'checked' : '' %> />
            <span class="toggle-slider"></span>
          </label>
        </div>

        <!-- Activity Type -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= lang === 'ar' ? 'نوع النشاط' : 'Activity Type' %></label>
            <p class="form-help"><%= lang === 'ar' ? 'نوع الحالة التي يعرضها البوت' : 'The type of activity displayed on the bot' %></p>
          </div>
          <select id="activity-type" class="form-select">
            <option value="none"      <%= (!cmdSettings.ACTIVITY_TYPE || cmdSettings.ACTIVITY_TYPE === 'none')    ? 'selected' : '' %>><%= lang === 'ar' ? 'بدون' : 'None' %></option>
            <option value="Playing"   <%= cmdSettings.ACTIVITY_TYPE === 'Playing'   ? 'selected' : '' %>><%= lang === 'ar' ? 'يلعب' : 'Playing' %></option>
            <option value="Streaming" <%= cmdSettings.ACTIVITY_TYPE === 'Streaming' ? 'selected' : '' %>><%= lang === 'ar' ? 'يبث' : 'Streaming' %></option>
            <option value="Listening" <%= cmdSettings.ACTIVITY_TYPE === 'Listening' ? 'selected' : '' %>><%= lang === 'ar' ? 'يستمع' : 'Listening' %></option>
            <option value="Watching"  <%= cmdSettings.ACTIVITY_TYPE === 'Watching'  ? 'selected' : '' %>><%= lang === 'ar' ? 'يشاهد' : 'Watching' %></option>
            <option value="Competing" <%= cmdSettings.ACTIVITY_TYPE === 'Competing' ? 'selected' : '' %>><%= lang === 'ar' ? 'ينافس' : 'Competing' %></option>
            <option value="Custom"    <%= cmdSettings.ACTIVITY_TYPE === 'Custom'    ? 'selected' : '' %>><%= lang === 'ar' ? 'مخصص' : 'Custom' %></option>
          </select>
        </div>

        <!-- Activity Name (hidden when none) -->
        <div class="form-row activity-name-row <%= (cmdSettings.ACTIVITY_TYPE && cmdSettings.ACTIVITY_TYPE !== 'none') ? '' : 'hidden' %>" id="activity-name-row">
          <div class="form-row-left">
            <label class="form-label"><%= lang === 'ar' ? 'نص النشاط' : 'Activity Text' %></label>
            <p class="form-help"><%= lang === 'ar' ? 'النص الذي يظهر بجانب نوع النشاط' : 'The text shown next to the activity type' %></p>
          </div>
          <input type="text" id="activity-name" class="form-input" value="<%= cmdSettings.ACTIVITY_NAME || '' %>" maxlength="128" placeholder="<%= lang === 'ar' ? 'نص النشاط...' : 'Activity text...' %>" />
        </div>

        <!-- Status -->
        <div class="form-row">
          <div class="form-row-left">
            <label class="form-label"><%= lang === 'ar' ? 'حالة البوت' : 'Bot Status' %></label>
            <p class="form-help"><%= lang === 'ar' ? 'الحالة الظاهرة للبوت على الديسكورد' : 'Presence status shown for the bot on Discord' %></p>
          </div>
          <!-- Custom status picker (hidden native select keeps value for all existing JS) -->
          <div class="status-picker" id="status-picker">
            <button type="button" class="status-pick-trigger" id="status-pick-trigger" aria-haspopup="listbox" aria-expanded="false">
              <span class="sp-dot" id="status-pick-dot"></span>
              <span id="status-pick-label"></span>
            </button>
            <div class="status-pick-menu" id="status-pick-menu" role="listbox">
              <button type="button" class="sp-opt" data-val="ONLINE" role="option">
                <span class="sp-dot online"></span>
                <%= lang === 'ar' ? 'متصل' : 'Online' %>
              </button>
              <button type="button" class="sp-opt" data-val="IDLE" role="option">
                <span class="sp-dot idle"></span>
                <%= lang === 'ar' ? 'بعيد' : 'Idle' %>
              </button>
              <button type="button" class="sp-opt" data-val="DND" role="option">
                <span class="sp-dot dnd"></span>
                <%= lang === 'ar' ? 'مشغول' : 'Do Not Disturb' %>
              </button>
              <button type="button" class="sp-opt" data-val="INVISIBLE" role="option">
                <span class="sp-dot invisible"></span>
                <%= lang === 'ar' ? 'مخفي' : 'Invisible' %>
              </button>
            </div>
          </div>
          <select id="bot-status" style="display:none">
            <option value="ONLINE"    <%= (!cmdSettings.STATUS || cmdSettings.STATUS === 'ONLINE')    ? 'selected' : '' %>>Online</option>
            <option value="IDLE"      <%= cmdSettings.STATUS === 'IDLE'      ? 'selected' : '' %>>Idle</option>
            <option value="DND"       <%= cmdSettings.STATUS === 'DND'       ? 'selected' : '' %>>Do Not Disturb</option>
            <option value="INVISIBLE" <%= cmdSettings.STATUS === 'INVISIBLE' ? 'selected' : '' %>>Invisible</option>
          </select>
        </div>

      </div>
    </div>

    <!-- ══ Protection Access Card ══ -->
    <div class="card card-mt" id="prot-access-card">
      <div class="card-header">
        <div class="card-header-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 18 18"><path d="M9 1L2 4.5V9c0 4.418 3.083 8.572 7 9.5 3.917-.928 7-5.082 7-9.5V4.5L9 1z" fill="currentColor" fill-opacity="0.4"/><path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 7.5l2.5 2.5 3.5-3.5 1 1-4.5 4.5-3.5-3.5 1-1z" fill="currentColor"/></svg>
        </div>
        <div style="flex:1;">
          <h3 style="font-size:.95rem;font-weight:700;"><%= lang === 'ar' ? 'صلاحيات صفحة الحماية' : 'Protection Page Access' %></h3>
        </div>
        <a href="/dashboard/<%= guildId %>/protection" class="btn btn-ghost nav-link" style="font-size:.78rem;padding:6px 12px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          <%= lang === 'ar' ? 'فتح صفحة الحماية' : 'Open Security Page' %>
        </a>
      </div>
      <div class="card-body">
        <div class="form-row" style="align-items:flex-start;flex-direction:column;gap:12px;border-bottom:none;padding-bottom:8px;">
          <p class="form-help" style="max-width:600px;line-height:1.7;">
            <%= lang === 'ar'
              ? 'المستخدمون في هذه القائمة يمكنهم الوصول وتعديل إعدادات الحماية. المستخدم الأول في القائمة يُعتبر مسؤولاً أعلى. إذا كانت القائمة فارغة، يُطبَّق وصول مالكي اللوحة فقط.'
              : 'Users listed here can access and edit the Security page. The first user is the top admin. If the list is empty, only dashboard owners have access.' %>
          </p>

          <!-- Current perm users -->
          <div id="perm-users-list" style="display:flex;flex-wrap:wrap;gap:10px;width:100%;">
            <% protectionPerms.forEach((u, idx) => { %>
            <div class="perm-user-chip" data-uid="<%= u.id %>" style="display:flex;align-items:center;gap:8px;padding:6px 10px 6px 6px;border-radius:12px;background:rgba(124,58,237,.08);border:1px solid rgba(124,58,237,.2);max-width:240px;">
              <% if (u.avatar) { %>
                <img src="<%= u.avatar %>" style="width:26px;height:26px;border-radius:50%;object-fit:cover;flex-shrink:0;" alt="<%= u.displayName %>" />
              <% } else { %>
                <div style="width:26px;height:26px;border-radius:50%;background:rgba(124,58,237,.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.78rem;font-weight:700;"><%= u.displayName.charAt(0).toUpperCase() %></div>
              <% } %>
              <div style="min-width:0;">
                <div style="font-size:.8rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;"><%= u.displayName %><% if (idx===0) { %> <span style="font-size:.62rem;color:var(--gold-l);background:rgba(217,119,6,.15);border:1px solid rgba(217,119,6,.3);border-radius:6px;padding:1px 6px;margin-left:4px;">★</span><% } %></div>
                <div style="font-size:.7rem;color:var(--muted);">@<%= u.username %></div>
              </div>
              <% if (isOwner) { %>
              <button onclick="removePermUser('<%= u.id %>')" style="background:none;border:none;cursor:pointer;color:var(--muted);display:flex;align-items:center;padding:2px;margin-left:auto;transition:color .15s;flex-shrink:0;" onmouseover="this.style.color='#f87171'" onmouseout="this.style.color='var(--muted)'" title="<%= lang==='ar'?'إزالة':'Remove' %>">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
              <% } %>
            </div>
            <% }) %>
            <% if (protectionPerms.length === 0) { %>
            <div style="font-size:.8rem;color:var(--muted);padding:6px 0;font-style:italic;">
              <%= lang === 'ar' ? 'لا يوجد مستخدمون — يُطبَّق وصول مالكي اللوحة' : 'No users added — dashboard owners have access' %>
            </div>
            <% } %>
          </div>

          <!-- Add user row (only for owners/top admin) -->
          <% if (isOwner) { %>
          <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <input type="text" id="perm-user-id-input" placeholder="<%= lang==='ar'?'أدخل Discord User ID':'Enter Discord User ID' %>"
              style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;color:var(--white);font-size:.82rem;font-family:inherit;padding:8px 13px;outline:none;transition:border-color .18s;width:230px;"
              onfocus="this.style.borderColor='var(--purple)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'" />
            <button class="btn btn-primary" style="font-size:.8rem;padding:8px 14px;" onclick="lookupPermUser()">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <%= lang === 'ar' ? 'بحث وإضافة' : 'Search & Add' %>
            </button>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ══ UCM Backdrop ══ -->
    <div id="ucm-backdrop" onclick="_ucmBackdropClick(event)" style="display:none;position:fixed;inset:0;z-index:9990;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);align-items:center;justify-content:center;">
      <div id="ucm-modal" role="dialog" aria-modal="true" style="width:300px;border-radius:20px;background:rgba(15,8,35,.98);border:1px solid rgba(124,58,237,.3);box-shadow:0 20px 60px rgba(0,0,0,.8);overflow:hidden;position:relative;">
        <div id="ucm-banner" style="height:80px;background:linear-gradient(135deg,rgba(124,58,237,.5),rgba(6,182,212,.3));"></div>
        <div style="position:relative;padding:0 20px 20px;">
          <div style="position:absolute;top:-28px;left:16px;width:56px;height:56px;border-radius:50%;border:4px solid rgba(15,8,35,.98);overflow:hidden;background:#1a1035;">
            <img id="ucm-avatar" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:block;" />
          </div>
          <div style="padding-top:34px;">
            <div id="ucm-display-name" style="font-size:1rem;font-weight:800;margin-bottom:2px;"></div>
            <div id="ucm-username" style="font-size:.78rem;color:var(--muted);margin-bottom:4px;"></div>
            <div id="ucm-nick" style="font-size:.78rem;color:var(--purple-l);font-style:italic;margin-bottom:4px;display:none;"></div>
            <div id="ucm-id" style="font-size:.68rem;color:rgba(255,255,255,.3);font-family:'Orbitron',monospace;letter-spacing:.05em;"></div>
          </div>
          <div style="height:1px;background:rgba(255,255,255,.07);margin:14px 0;"></div>
          <div style="font-size:.85rem;font-weight:600;text-align:center;margin-bottom:14px;color:var(--white);">
            <%= lang === 'ar' ? 'هل تريد إضافة هذا المستخدم؟' : 'Add this user to protection access?' %>
          </div>
          <div style="display:flex;gap:10px;justify-content:center;">
            <button class="btn btn-ghost" onclick="cancelUserConfirm()" style="min-width:100px;"><%= lang === 'ar' ? 'إلغاء' : 'Cancel' %></button>
            <button class="btn btn-primary" onclick="confirmUserAdd()" style="min-width:100px;"><%= lang === 'ar' ? 'تأكيد' : 'Confirm' %></button>
          </div>
        </div>
      </div>
    </div>

    <!-- Save Bar -->
    <div class="save-bar" id="save-bar">
      <span class="save-bar-text"><%= lang === 'ar' ? 'لديك تغييرات غير محفوظة' : 'You have unsaved changes' %></span>
      <div class="save-bar-actions">
        <button class="btn btn-ghost" id="reset-btn" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
          <%= lang === 'ar' ? 'تراجع' : 'Reset' %>
        </button>
        <button class="btn btn-primary" id="save-btn" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          <%= lang === 'ar' ? 'حفظ التغييرات' : 'Save Changes' %>
        </button>
      </div>
    </div>
  </main>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <!-- Three.js stars -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  <script>
    (function(){
      const canvas=document.getElementById('c');
      const renderer=new THREE.WebGLRenderer({canvas,antialias:false});
      renderer.setPixelRatio(1);renderer.setSize(innerWidth,innerHeight);
      renderer.setClearColor(0x040010,1);
      const scene=new THREE.Scene();
      const camera=new THREE.PerspectiveCamera(70,innerWidth/innerHeight,0.1,500);
      camera.position.z=1;
      const N=2800,pos=new Float32Array(N*3);
      for(let i=0;i<N*3;i++)pos[i]=(Math.random()-.5)*240;
      const geo=new THREE.BufferGeometry();
      geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
      const mat=new THREE.PointsMaterial({color:0xb8b0ff,size:0.24,transparent:true,opacity:0.45,depthWrite:false});
      scene.add(new THREE.Points(geo,mat));
      let mx=0,t=0;
      document.addEventListener('mousemove',e=>{mx=(e.clientX/innerWidth-.5)*.25;});
      window.addEventListener('resize',()=>{camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight);});
      const stars=scene.children[0];
      (function render(){requestAnimationFrame(render);t+=0.00022;stars.rotation.y=t+mx*.15;renderer.render(scene,camera);})();
    })();

    /* ── Protection Perms UCM ── */
    let _pendingUserId = null;

    async function lookupPermUser() {
      const inp = document.getElementById('perm-user-id-input');
      const uid = inp ? inp.value.trim() : '';
      if (!uid) { showToast('<%= lang==="ar"?"أدخل معرف المستخدم":"Enter a user ID" %>', 'error'); return; }
      try {
        const resp = await fetch(`/api/user/${uid}?guildId=<%= guildId %>`);
        if (!resp.ok) { showToast('<%= lang==="ar"?"المستخدم غير موجود":"User not found" %>', 'error'); return; }
        const u = await resp.json();
        _pendingUserId = u.id;
        const av = document.getElementById('ucm-avatar');
        av.src = u.avatar || '';
        // nick line
        const nickEl = document.getElementById('ucm-nick');
        if (u.nickname) { nickEl.textContent = `"${u.nickname}"`; nickEl.style.display = 'block'; }
        else { nickEl.style.display = 'none'; }
        // banner color
        const banner = document.getElementById('ucm-banner');
        if (u.bannerColor) { banner.style.background = u.bannerColor; }
        document.getElementById('ucm-display-name').textContent = u.displayName || u.username;
        document.getElementById('ucm-username').textContent = '@' + u.username;
        document.getElementById('ucm-id').textContent = u.id;
        const backdrop = document.getElementById('ucm-backdrop');
        backdrop.style.display = 'flex';
      } catch(e) { showToast('<%= lang==="ar"?"حدث خطأ غير متوقع":"Unexpected error" %>', 'error'); }
    }

    async function confirmUserAdd() {
      if (!_pendingUserId) return;
      try {
        const resp = await fetch(`/api/<%= guildId %>/protection/perms/add`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: _pendingUserId })
        });
        if (resp.ok) {
          location.reload();
        } else {
          const j = await resp.json().catch(() => ({}));
          showToast(j.error || '<%= lang==="ar"?"حدث خطأ":"Error" %>', 'error');
          cancelUserConfirm();
        }
      } catch(e) { showToast('<%= lang==="ar"?"حدث خطأ غير متوقع":"Unexpected error" %>', 'error'); }
    }

    function cancelUserConfirm() {
      const bd = document.getElementById('ucm-backdrop');
      if (bd) bd.style.display = 'none';
      _pendingUserId = null;
    }

    function _ucmBackdropClick(e) {
      if (e.target === document.getElementById('ucm-backdrop')) cancelUserConfirm();
    }

    async function removePermUser(uid) {
      const msg = '<%= lang==="ar"?"هل تريد إزالة هذا المستخدم من صلاحيات الحماية؟":"Remove this user from protection access?" %>';
      if (!confirm(msg)) return;
      try {
        const resp = await fetch(`/api/<%= guildId %>/protection/perms/${uid}`, { method: 'DELETE' });
        if (resp.ok) {
          location.reload();
        } else {
          const j = await resp.json().catch(() => ({}));
          showToast(j.error || '<%= lang==="ar"?"حدث خطأ":"Error" %>', 'error');
        }
      } catch(e) { showToast('<%= lang==="ar"?"حدث خطأ غير متوقع":"Unexpected error" %>', 'error'); }
    }

    /* ── Language ── */
    document.getElementById('lang-select').addEventListener('change', function () {
      const u = new URL(window.location.href);
      u.searchParams.set('lang', this.value);
      window.location.href = u.toString();
    });

    /* ── Mobile nav ── */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');
    const sortBtn     = document.getElementById('mgmt-sort-btn');
    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; }
    function openNav()   { if (navSidebar) { navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; } }
    function closeNav()  { if (navSidebar) { navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; } }
    if (menuToggle) menuToggle.addEventListener('click', e => { e.stopPropagation(); mgmtSidebar.classList.contains('open') ? closeMgmt() : openMgmt(); });
    if (navOverlay) navOverlay.addEventListener('click', () => { closeMgmt(); closeNav(); });
    if (sortBtn)    sortBtn.addEventListener('click', e => { e.stopPropagation(); if (navSidebar&&navSidebar.classList.contains('open')) { closeNav(); } else { closeMgmt(); openNav(); } });
    document.addEventListener('keydown', e => { if (e.key==='Escape') { closeMgmt(); closeNav(); } });

    /* ── Mgmt section collapse ── */
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const body = this.nextElementSibling;
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        this.classList.toggle('open', !isOpen);
      });
    });

    /* ── Page transitions ── */
    function fadeOut(href) {
      const ov = document.getElementById('ov');
      ov.classList.add('leave');
      setTimeout(() => { window.location.href = href; }, 360);
    }
    document.querySelectorAll('a.nav-link').forEach(a => {
      a.addEventListener('click', function (e) {
        if (this.target === '_blank') return;
        e.preventDefault(); fadeOut(this.href);
      });
    });

    /* ── Toast ── */
    function showToast(msg, type = 'success') {
      const el = document.getElementById('toast');
      const icon = type === 'success'
        ? '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>'
        : '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
      el.className = 'toast ' + type;
      el.innerHTML = icon + msg;
      el.classList.add('show');
      setTimeout(() => el.classList.remove('show'), 3500);
    }

    /* ── Copy bot ID ── */
    const botIdEl = document.getElementById('bot-id-copy');
    if (botIdEl && botIdEl.textContent.trim() !== '—') {
      botIdEl.addEventListener('click', () => {
        navigator.clipboard.writeText(botIdEl.textContent.trim()).then(() => {
          showToast('<%= lang === "ar" ? "تم نسخ الـ ID" : "ID copied!" %>');
        });
      });
    }

    /* ── Save Bar: System Settings ── */
    const saveBar  = document.getElementById('save-bar');
    const saveBtn  = document.getElementById('save-btn');
    const resetBtn = document.getElementById('reset-btn');

    const origVals = {
      enablePrefix : document.getElementById('enable-prefix').checked,
      prefixSymbol : document.getElementById('prefix-symbol').value,
      enableSlash  : document.getElementById('enable-slash').checked,
      activityType : document.getElementById('activity-type').value,
      activityName : document.getElementById('activity-name').value,
      botStatus    : document.getElementById('bot-status').value,
    };

    function checkDirty() {
      const dirty =
        document.getElementById('enable-prefix').checked !== origVals.enablePrefix ||
        document.getElementById('prefix-symbol').value   !== origVals.prefixSymbol  ||
        document.getElementById('enable-slash').checked  !== origVals.enableSlash  ||
        document.getElementById('activity-type').value   !== origVals.activityType ||
        document.getElementById('activity-name').value   !== origVals.activityName ||
        document.getElementById('bot-status').value      !== origVals.botStatus;
      saveBar.classList.toggle('visible', dirty);
    }

    ['enable-prefix','enable-slash'].forEach(id => document.getElementById(id).addEventListener('change', checkDirty));
    ['activity-type','activity-name','bot-status','prefix-symbol'].forEach(id => {
      const el = document.getElementById(id);
      el.addEventListener('input', checkDirty);
      el.addEventListener('change', checkDirty);
    });

    /* Prefix toggle shows/hides prefix symbol row */
    const prefixToggle    = document.getElementById('enable-prefix');
    const prefixSymbolRow = document.getElementById('prefix-symbol-row');
    prefixToggle.addEventListener('change', () => {
      prefixSymbolRow.classList.toggle('hidden', !prefixToggle.checked);
    });

    /* Activity name visibility */
    const actTypeEl  = document.getElementById('activity-type');
    const actNameRow = document.getElementById('activity-name-row');
    function syncActivityRow() { actNameRow.classList.toggle('hidden', actTypeEl.value === 'none'); }
    actTypeEl.addEventListener('change', syncActivityRow);

    /* ── Custom status picker ── */
    (function(){
      const native  = document.getElementById('bot-status');
      const trigger = document.getElementById('status-pick-trigger');
      const pMenu   = document.getElementById('status-pick-menu');
      const pDot    = document.getElementById('status-pick-dot');
      const pLbl    = document.getElementById('status-pick-label');
      if (!trigger) return;
      const DOT_CLS = { ONLINE:'online', IDLE:'idle', DND:'dnd', INVISIBLE:'invisible' };
      const LABELS  = { ONLINE:'<%= lang === "ar" ? "متصل" : "Online" %>', IDLE:'<%= lang === "ar" ? "بعيد" : "Idle" %>', DND:'<%= lang === "ar" ? "مشغول" : "Do Not Disturb" %>', INVISIBLE:'<%= lang === "ar" ? "مخفي" : "Invisible" %>' };
      let _syncing = false;
      function syncPicker(val){
        pDot.className = 'sp-dot '+(DOT_CLS[val]||'online');
        pLbl.textContent = LABELS[val]||val;
        document.querySelectorAll('.sp-opt').forEach(o=>o.classList.toggle('active',o.dataset.val===val));
      }
      syncPicker(native.value||'ONLINE');
      /* Move menu to body to escape card overflow:hidden */
      document.body.appendChild(pMenu);
      function positionMenu(){
        const r   = trigger.getBoundingClientRect();
        const vw  = window.innerWidth;
        const vh  = window.innerHeight;
        const w   = Math.max(r.width, 180);
        let left  = r.left;
        if (left + w > vw - 8) left = vw - w - 8;
        if (left < 8) left = 8;
        pMenu.style.top   = (r.bottom + 6) + 'px';
        pMenu.style.left  = left + 'px';
        pMenu.style.width = w + 'px';
      }
      trigger.addEventListener('click', e => {
        e.stopPropagation();
        const open = pMenu.classList.toggle('open');
        trigger.setAttribute('aria-expanded', open);
        if (open) positionMenu();
      });
      document.querySelectorAll('.sp-opt').forEach(o=>{
        o.addEventListener('mousedown', e => { e.stopPropagation(); e.preventDefault(); });
        o.addEventListener('click', e => {
          e.stopPropagation();
          _syncing=true;
          native.value = o.dataset.val;
          native.dispatchEvent(new Event('change'));
          syncPicker(o.dataset.val);
          pMenu.classList.remove('open');
          trigger.setAttribute('aria-expanded','false');
          _syncing=false;
        });
      });
      document.addEventListener('click', e => {
        if (!trigger.contains(e.target) && !pMenu.contains(e.target)) {
          pMenu.classList.remove('open');
          trigger.setAttribute('aria-expanded','false');
        }
      });
      window.addEventListener('resize', () => { if(pMenu.classList.contains('open')) positionMenu(); });
      window.addEventListener('scroll', () => { if(pMenu.classList.contains('open')) positionMenu(); }, true);
      native.addEventListener('change', () => { if (!_syncing) syncPicker(native.value); });
      window._syncStatusPicker = syncPicker;
    })();

    /* Reset */
    resetBtn.addEventListener('click', () => {
      document.getElementById('enable-prefix').checked = origVals.enablePrefix;
      document.getElementById('prefix-symbol').value   = origVals.prefixSymbol;
      document.getElementById('enable-slash').checked  = origVals.enableSlash;
      document.getElementById('activity-type').value   = origVals.activityType;
      document.getElementById('activity-name').value   = origVals.activityName;
      document.getElementById('bot-status').value      = origVals.botStatus;
      if (window._syncStatusPicker) window._syncStatusPicker(origVals.botStatus);
      prefixSymbolRow.classList.toggle('hidden', !origVals.enablePrefix);
      syncActivityRow();
      checkDirty();
    });

    /* Save */
    saveBtn.addEventListener('click', async () => {
      saveBtn.disabled = true;
      const origHTML = saveBtn.innerHTML;
      saveBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> <%= lang === "ar" ? "جاري الحفظ..." : "Saving..." %>';
      try {
        /* Prefix comes directly from the select — always valid */
        const prefixVal = document.getElementById('prefix-symbol').value;
        const res = await fetch('/dashboard/<%= guildId %>/setting/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            PREFIX: prefixVal,
            COMMANDS: {
              ENABLE_PREFIX         : document.getElementById('enable-prefix').checked,
              ENABLE_SLASH_COMMANDS : document.getElementById('enable-slash').checked,
              ACTIVITY_TYPE         : document.getElementById('activity-type').value,
              ACTIVITY_NAME         : document.getElementById('activity-name').value,
              STATUS                : document.getElementById('bot-status').value,
            }
          }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');

        origVals.enablePrefix = document.getElementById('enable-prefix').checked;
        origVals.prefixSymbol = document.getElementById('prefix-symbol').value;
        origVals.enableSlash  = document.getElementById('enable-slash').checked;
        origVals.activityType = document.getElementById('activity-type').value;
        origVals.activityName = document.getElementById('activity-name').value;
        origVals.botStatus    = document.getElementById('bot-status').value;

        /* Update status badge */
        const status = origVals.botStatus.toLowerCase();
        const badge  = document.getElementById('status-badge');
        if (badge) {
          badge.className = 'bot-status-badge ' + status;
          const dot = badge.querySelector('.dot-status');
          if (dot) dot.className = 'dot-status dot-' + status;
          badge.lastChild.textContent = ' ' + origVals.botStatus;
        }

        saveBar.classList.remove('visible');
        showToast('<%= lang === "ar" ? "تم حفظ الإعدادات" : "Settings saved" %>');
      } catch (e) {
        showToast(e.message, 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.innerHTML = origHTML;
      }
    });

    /* ── Bot Description ── */
    (function() {
      const textarea  = document.getElementById('bot-desc-input');
      const counter   = document.getElementById('bot-desc-counter');
      const saveBtn   = document.getElementById('save-desc-btn');
      const MAX       = 400;

      function updateCounter() {
        const len = textarea.value.length;
        counter.textContent = len + ' / ' + MAX;
        counter.classList.toggle('warn', len >= MAX);
      }
      updateCounter();
      textarea.addEventListener('input', updateCounter);

      saveBtn.addEventListener('click', async () => {
        const val = textarea.value.trim();
        const origHTML = saveBtn.innerHTML;
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
        try {
          const res  = await fetch('/dashboard/<%= guildId %>/setting/bot-description', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ description: val }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Error');
          textarea.value = data.description;
          updateCounter();
          showToast('<%= lang === "ar" ? "تم تحديث وصف البوت" : "Bot description updated" %>');
        } catch (e) {
          showToast(e.message, 'error');
        } finally {
          saveBtn.disabled = false;
          saveBtn.innerHTML = origHTML;
        }
      });
    })();

    /* ── Bot Username ── */
    document.getElementById('save-username-btn').addEventListener('click', async () => {
      const input = document.getElementById('bot-username-input');
      const val = (input.value || '').trim();
      if (val.length < 2 || val.length > 32) {
        showToast('<%= lang === "ar" ? "الاسم يجب أن يكون بين 2 و32 حرف" : "Username must be 2-32 characters" %>', 'error');
        return;
      }
      const btn = document.getElementById('save-username-btn');
      const origHTML = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
      try {
        const res  = await fetch('/dashboard/<%= guildId %>/setting/bot-username', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: val }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        document.getElementById('bot-username-display').textContent = data.username;
        input.value = data.username;
        showToast('<%= lang === "ar" ? "تم تغيير اسم البوت" : "Bot username updated" %>');
      } catch (e) {
        showToast(e.message, 'error');
      } finally {
        btn.disabled = false;
        btn.innerHTML = origHTML;
      }
    });

    /* ── Avatar Upload ── */
    const avatarFileInput  = document.getElementById('avatar-file-input');
    const avatarUploading  = document.getElementById('avatar-uploading');
    document.getElementById('avatar-edit-btn').addEventListener('click', () => avatarFileInput.click());
    avatarFileInput.addEventListener('change', async () => {
      if (!avatarFileInput.files.length) return;
      avatarUploading.classList.add('active');
      try {
        const fd = new FormData();
        fd.append('file', avatarFileInput.files[0]);
        const res  = await fetch('/dashboard/<%= guildId %>/setting/bot-avatar', { method: 'POST', body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        const preview  = document.getElementById('bot-avatar-preview');
        const fallback = document.getElementById('bot-avatar-fallback');
        if (data.avatar) {
          preview.src = data.avatar + '?t=' + Date.now();
          preview.style.display = '';
          if (fallback) fallback.style.display = 'none';
        }
        showToast('<%= lang === "ar" ? "تم تغيير الصورة الرمزية" : "Avatar updated" %>');
      } catch (e) {
        showToast(e.message, 'error');
      } finally {
        avatarUploading.classList.remove('active');
        avatarFileInput.value = '';
      }
    });

    /* ── Banner Upload ── */
    const bannerFileInput = document.getElementById('banner-file-input');
    document.getElementById('banner-edit-btn').addEventListener('click', () => bannerFileInput.click());
    bannerFileInput.addEventListener('change', async () => {
      if (!bannerFileInput.files.length) return;
      const reader = new FileReader();
      reader.onload = e => {
        const p = document.getElementById('bot-banner-preview');
        p.src = e.target.result;
        p.style.display = '';
      };
      reader.readAsDataURL(bannerFileInput.files[0]);
      try {
        const fd = new FormData();
        fd.append('file', bannerFileInput.files[0]);
        const res  = await fetch('/dashboard/<%= guildId %>/setting/bot-banner', { method: 'POST', body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        if (data.banner) {
          document.getElementById('bot-banner-preview').src = data.banner + '?t=' + Date.now();
        }
        showToast('<%= lang === "ar" ? "تم تغيير البانر" : "Banner updated" %>');
      } catch (e) {
        showToast(e.message, 'error');
      } finally {
        bannerFileInput.value = '';
      }
    });
  </script>

  <script>
    /* ── Profile sidebar ── */
    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn      = document.getElementById('open-profile');
    const closeBtn     = document.getElementById('close-profile');
    const copyId       = document.getElementById('prof-copy-id');
    const bannerSolid  = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;
    function openProfile()  { if (!profSidebar) return; profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    function closeProfile() { if (!profSidebar) return; profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
    if (openBtn)  openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    if (profBackdrop) profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });
    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '✓ Copied!'; copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }
  </script>
</body>
</html>

