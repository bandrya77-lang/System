        <% } else { %>
          <div class="mgmt-footer-av-fallback"><%= (user.displayName || user.username).charAt(0).toUpperCase() %></div>
        <% } %>
        <span class="mgmt-footer-name">@<%= user.username %></span>
      </div>
      <button class="mgmt-footer-dots" aria-label="User menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 18 18"><circle cx="9" cy="9" r="1.25" fill="currentColor"/><circle cx="3.25" cy="9" r="1.25" fill="currentColor"/><circle cx="14.75" cy="9" r="1.25" fill="currentColor"/></svg>
      </button>
    </div>
  </aside>

  <!-- ── Main Content ── -->
  <% 
    const pc = protectionCfg || {};
    const actionLabels = {
      '1': lang==='ar'?'طرد':'Kick',
      '2': lang==='ar'?'إزالة الرتب':'Remove Roles',
      '3': lang==='ar'?'حظر':'Ban',
      '4': lang==='ar'?'كتم':'Mute',
      '5': lang==='ar'?'سجن':'Jail'
    };
  %>
  <main class="main">
    <div class="page-header">
      <div>
        <h2><%= lang === 'ar' ? 'الأمان' : 'Security' %></h2>
        <p><%= lang === 'ar' ? 'إعدادات نظام الحماية لحماية السيرفر من الإجراءات الضارة' : 'Configure server protection against harmful actions' %></p>
      </div>
      <span id="global-status-badge" class="status-badge <%= pc.enable!==false?'on':'off' %>">
        <span class="status-dot <%= pc.enable!==false?'on':'off' %>"></span>
        <%= pc.enable!==false?(lang==='ar'?'مفعّل':'Active'):(lang==='ar'?'معطّل':'Disabled') %>
      </span>
    </div>
    <div class="divider"></div>

    <% if (!canEdit) { %>
    <div class="lock-banner">
      <div class="lock-banner-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <div class="lock-banner-text">
        <h4><%= lang==='ar'?'محمية — لا تملك صلاحية':'Protected — No Access' %></h4>
        <p><%= lang==='ar'?'لا يمكن تعديل إعدادات الحماية. اطلب من المسؤول منحك صلاحية من صفحة الإعدادات.':'You cannot edit protection settings. Ask an admin to grant access from Settings.' %></p>
      </div>
      <a href="/dashboard/<%= guildId %>/setting" class="btn btn-sm btn-ghost lock-banner-btn nav-link"><%= lang==='ar'?'الإعدادات':'Settings' %></a>
    </div>
    <% } %>

    <div class="<%= !canEdit?'prot-locked':'' %>">

      <!-- Global Settings Card -->
      <div class="card">
        <div class="card-header">
          <div class="card-header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 18 18"><path d="M9 1L2 4.5V9c0 4.418 3.083 8.572 7 9.5 3.917-.928 7-5.082 7-9.5V4.5L9 1z" fill="currentColor" fill-opacity="0.4"/><path fill-rule="evenodd" clip-rule="evenodd" d="M6.5 7.5l2.5 2.5 3.5-3.5 1 1-4.5 4.5-3.5-3.5 1-1z" fill="currentColor"/></svg>
          </div>
          <h3><%= lang==='ar'?'إعدادات عامة':'Global Settings' %></h3>
        </div>
        <div class="card-body">
          <div class="form-row">
            <div class="form-row-left">
              <label class="form-label"><%= lang==='ar'?'تفعيل نظام الحماية':'Enable Protection System' %></label>
              <p class="form-help"><%= lang==='ar'?'تشغيل أو إيقاف جميع وحدات الحماية دفعة واحدة':'Toggle all protection modules on or off at once' %></p>
            </div>
            <label class="toggle-switch">
              <input type="checkbox" id="global-enable" data-key="enable" <%= pc.enable!==false?'checked':'' %> />
              <span class="toggle-slider"></span>
            </label>
          </div>
          <div class="form-row" style="align-items:flex-start;">
            <div class="form-row-left">
              <label class="form-label"><%= lang==='ar'?'الرتب المعفاة (عامة)':'Global Whitelist Roles' %></label>
              <p class="form-help"><%= lang==='ar'?'هذه الرتب معفاة من جميع وحدات الحماية':'These roles are exempt from all protection modules' %></p>
            </div>
            <div style="flex-shrink:0;max-width:320px;">
              <div class="role-multi" id="global-wl-chips">
                <% (pc.whitelist_roles||[]).forEach(rid => {
                  const role = guildRoles.find(r=>r.id===rid);
                  const rname = role ? role.name : rid;
                  const rcolor = role && role.color ? role.color : '#888';
                %>
                <span class="role-chip" data-rid="<%= rid %>">
                  <span class="role-chip-dot" data-color="<%= rcolor %>"></span>
                  <span><%= rname %></span>
                  <button class="role-chip-rm" onclick="removeGlobalRole('<%= rid %>')">×</button>
                </span>
                <% }) %>
                <div class="role-picker-wrap" id="global-wl-picker-wrap">
                  <button class="role-add-btn" onclick="toggleRolePicker('global-wl-dd')">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 5v14M5 12h14"/></svg>
                    <%= lang==='ar'?'إضافة':'Add' %>
                  </button>
                  <div class="role-picker-dd" id="global-wl-dd">
                    <% guildRoles.forEach(r => { %>
                      <div class="role-picker-item" data-rid="<%= r.id %>" data-rname="<%= r.name %>" data-rcolor="<%= r.color||'#888' %>" onclick="addGlobalRole(this.dataset.rid,this.dataset.rname,this.dataset.rcolor)">
                        <span class="dot" data-color="<%= r.color||'#888' %>"></span>
                        <span><%= r.name %></span>
                      </div>
                    <% }) %>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="form-row" style="align-items:flex-start;">
            <div class="form-row-left">
              <label class="form-label"><%= lang==='ar'?'الإجراءات المتاحة':'Available Actions' %></label>
              <p class="form-help"><%= lang==='ar'?'الأرقام المستخدمة عند اختيار الإجراء في كل وحدة':'Numbers used when selecting an action per module' %></p>
            </div>
            <div class="action-map">
              <% Object.entries(actionLabels).forEach(([num, label]) => { %>
                <div class="am-chip"><span class="am-num"><%= num %></span><span><%= label %></span></div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <!-- Protection Cards Grid -->
      <% 
        const protModules = [
          { key:'anti_ban',            icon:'red',    titleAr:'حماية من الحظر',      titleEn:'Anti-Ban',            helpAr:'يمنع المستخدمين من حظر أعداد كبيرة',           helpEn:'Prevents mass-banning by members',     hasLimit:true },
          { key:'anti_kick',           icon:'red',    titleAr:'حماية من الطرد',      titleEn:'Anti-Kick',           helpAr:'يمنع المستخدمين من طرد أعداد كبيرة',           helpEn:'Prevents mass-kicking by members',     hasLimit:true },
          { key:'anti_channel_create', icon:'orange', titleAr:'حماية إنشاء القنوات', titleEn:'Anti-Channel Create', helpAr:'يمنع إنشاء قنوات بكميات كبيرة',              helpEn:'Prevents mass channel creation',       hasLimit:true },
          { key:'anti_channel_delete', icon:'orange', titleAr:'حماية حذف القنوات',  titleEn:'Anti-Channel Delete', helpAr:'يمنع حذف قنوات بكميات كبيرة',                helpEn:'Prevents mass channel deletion',       hasLimit:true },
          { key:'anti_role_create',    icon:'cyan',   titleAr:'حماية إنشاء الرتب',   titleEn:'Anti-Role Create',    helpAr:'يمنع إنشاء رتب بكميات كبيرة',                helpEn:'Prevents mass role creation',          hasLimit:true },
          { key:'anti_role_delete',    icon:'cyan',   titleAr:'حماية حذف الرتب',    titleEn:'Anti-Role Delete',    helpAr:'يمنع حذف رتب بكميات كبيرة',                  helpEn:'Prevents mass role deletion',          hasLimit:true },
          { key:'anti_bots',           icon:'shield', titleAr:'حماية من البوتات',    titleEn:'Anti-Bots',           helpAr:'يمنع إضافة بوتات غير مصرح بها',              helpEn:'Prevents unauthorized bot additions',  hasLimit:false },
          { key:'anti_webhooks',       icon:'shield', titleAr:'حماية من الويب هوك',  titleEn:'Anti-Webhooks',       helpAr:'يمنع إنشاء webhooks غير مصرح بها',            helpEn:'Prevents unauthorized webhook creation', hasLimit:false },
        ];
      %>
      <div class="prot-grid">
        <% protModules.forEach(mod => {
          const cfg = pc[mod.key] || { enabled: false, limit: 5, action: '2', whitelist_roles: [] };
          const wlRoles = cfg.whitelist_roles || [];
        %>
        <div class="prot-card">
          <div class="prot-card-header">
            <div class="prot-card-icon <%= mod.icon %>">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <% if (mod.key==='anti_ban') { %><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="15" y1="9" x2="9" y2="15" stroke-linecap="round"/><line x1="9" y1="9" x2="15" y2="15" stroke-linecap="round"/>
                <% } else if (mod.key==='anti_kick') { %><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="8 12 11 15 16 9" stroke-linecap="round" stroke-linejoin="round"/>
                <% } else if (mod.key==='anti_channel_create') { %><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><line x1="9" y1="10" x2="15" y2="10" stroke-linecap="round"/><line x1="12" y1="7" x2="12" y2="13" stroke-linecap="round"/>
                <% } else if (mod.key==='anti_channel_delete') { %><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><line x1="9" y1="10" x2="15" y2="10" stroke-linecap="round"/>
                <% } else if (mod.key==='anti_role_create') { %><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="16" stroke-linecap="round"/><line x1="8" y1="12" x2="16" y2="12" stroke-linecap="round"/>
                <% } else if (mod.key==='anti_role_delete') { %><circle cx="12" cy="12" r="9"/><line x1="8" y1="12" x2="16" y2="12" stroke-linecap="round"/>
                <% } else if (mod.key==='anti_bots') { %><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="9" cy="11" r="1.2" fill="currentColor"/><circle cx="15" cy="11" r="1.2" fill="currentColor"/><path d="M8 15s1 2 4 2 4-2 4-2" stroke-linecap="round"/>
                <% } else { %><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                <% } %>
              </svg>
            </div>
            <span class="prot-card-title"><%= lang==='ar'?mod.titleAr:mod.titleEn %></span>
            <label class="toggle-switch">
              <input type="checkbox" data-key="<%= mod.key %>:enabled" <%= cfg.enabled?'checked':'' %> />
              <span class="toggle-slider"></span>
            </label>
          </div>
          <div class="prot-card-body">
            <% if (mod.hasLimit) { %>
            <div class="prot-row">
              <div class="prot-row-left">
                <div class="prot-row-label"><%= lang==='ar'?'الحد الأقصى':'Trigger Limit' %></div>
                <div class="prot-row-help"><%= lang==='ar'?'عدد المرات خلال 10 ثوانٍ قبل تفعيل العقوبة':'Number of actions per 10s before punishment' %></div>
              </div>
              <input type="number" class="prot-number" data-key="<%= mod.key %>:limit" value="<%= cfg.limit||5 %>" min="1" max="50" />
            </div>
            <% } %>
            <div class="prot-row">
              <div class="prot-row-left">
                <div class="prot-row-label"><%= lang==='ar'?'الإجراء':'Action' %></div>
                <div class="prot-row-help"><%= lang==='ar'?'العقوبة عند تجاوز الحد':'Punishment when limit is exceeded' %></div>
              </div>
              <select class="prot-select" data-key="<%= mod.key %>:action">
                <% Object.entries(actionLabels).forEach(([num, label]) => { %>
                  <option value="<%= num %>" <%= cfg.action===num?'selected':'' %>><%= num %> — <%= label %></option>
                <% }) %>
              </select>
            </div>
            <% if (mod.key !== 'anti_bots' && mod.key !== 'anti_webhooks') { %>
            <div class="prot-row" style="align-items:flex-start;flex-direction:column;gap:8px;">
              <div>
                <div class="prot-row-label"><%= lang==='ar'?'الرتب المعفاة':'Whitelist Roles' %></div>
                <div class="prot-row-help"><%= lang==='ar'?'معفاة من هذه الوحدة فقط':'Exempt from this module only' %></div>
              </div>
              <div class="role-multi" id="<%= mod.key %>-chips">
                <% wlRoles.forEach(rid => {
                  const role = guildRoles.find(r=>r.id===rid);
                  const rname = role?role.name:rid;
                  const rcolor = role&&role.color?role.color:'#888';
                %>
                <span class="role-chip" data-rid="<%= rid %>">
                  <span class="role-chip-dot" data-color="<%= rcolor %>"></span>
                  <span><%= rname %></span>
                  <button class="role-chip-rm" onclick="removeModRole('<%= mod.key %>','<%= rid %>')">×</button>
                </span>
                <% }) %>
                <div class="role-picker-wrap">
                  <button class="role-add-btn" onclick="toggleRolePicker('<%= mod.key %>-dd')">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 5v14M5 12h14"/></svg>
                    <%= lang==='ar'?'إضافة':'Add' %>
                  </button>
                  <div class="role-picker-dd" id="<%= mod.key %>-dd">
                    <% guildRoles.forEach(r => { %>
                      <div class="role-picker-item" data-mod="<%= mod.key %>" data-rid="<%= r.id %>" data-rname="<%= r.name %>" data-rcolor="<%= r.color||'#888' %>" onclick="addModRole(this.dataset.mod,this.dataset.rid,this.dataset.rname,this.dataset.rcolor)">
                        <span class="dot" data-color="<%= r.color||'#888' %>"></span>
                        <span><%= r.name %></span>
                      </div>
                    <% }) %>
                  </div>
                </div>
              </div>
            </div>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div><!-- /prot-grid -->

    </div><!-- /prot-locked -->

    <!-- Save Bar -->
    <div class="save-bar" id="save-bar">
      <span class="save-bar-text"><%= lang==='ar'?'لديك تغييرات غير محفوظة':'You have unsaved changes' %></span>
      <div class="save-bar-actions">
        <button class="btn btn-ghost btn-sm" id="reset-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
          <%= lang==='ar'?'تراجع':'Reset' %>
        </button>
        <button class="btn btn-primary btn-sm" id="save-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          <%= lang==='ar'?'حفظ':'Save' %>
        </button>
      </div>
    </div>
  </main>

  <div id="toast" class="toast"></div>

  <script src="https://cdn.jsdelivr.net/npm/three@0.152.2/build/three.min.js"></script>
  <script>
    const GUILD_ID  = '<%= guildId %>';
    const IS_LOCKED = '<%= canEdit %>' !== 'true';
    /* init data-color chips/dots painted by JS to avoid EJS-in-CSS lint errors */
    document.querySelectorAll('[data-color]').forEach(el => { el.style.background = el.dataset.color; });

    /* Snapshot */
    let snapshot = {};
    function captureSnapshot() {
      snapshot = {};
      document.querySelectorAll('[data-key]').forEach(el => {
        snapshot[el.dataset.key] = el.type==='checkbox' ? el.checked : el.value;
      });
      document.querySelectorAll('[id$="-chips"]').forEach(wrap => {
        const k = wrap.id.replace('-chips',':whitelist_roles');
        snapshot[k] = Array.from(wrap.querySelectorAll('.role-chip[data-rid]')).map(c=>c.dataset.rid);
      });
    }
    function isDirty() {
      if (IS_LOCKED) return false;
      for (const [key, val] of Object.entries(snapshot)) {
        if (Array.isArray(val)) {
          const wrapId = key.replace(':whitelist_roles','-chips');
          const wrap = document.getElementById(wrapId);
          if (wrap) {
            const cur = Array.from(wrap.querySelectorAll('.role-chip[data-rid]')).map(c=>c.dataset.rid);
            if (JSON.stringify(cur)!==JSON.stringify(val)) return true;
          }
        } else {
          const el = document.querySelector(`[data-key="${key}"]`);
          if (el) {
            const cur = el.type==='checkbox' ? el.checked : el.value;
            if (String(cur)!==String(val)) return true;
          }
        }
      }
      return false;
    }
    function checkDirty() {
      document.getElementById('save-bar').classList.toggle('visible', IS_LOCKED ? false : isDirty());
    }
    document.addEventListener('change', e => { if (e.target.closest('[data-key]')) checkDirty(); });
    document.addEventListener('input',  e => { if (e.target.closest('[data-key]')) checkDirty(); });

    /* Global enable badge */
    document.getElementById('global-enable')?.addEventListener('change', function() {
      const b = document.getElementById('global-status-badge');
      if (this.checked) { b.className='status-badge on'; b.innerHTML='<span class="status-dot on"></span><%= lang==="ar"?"مفعّل":"Active" %>'; }
      else              { b.className='status-badge off'; b.innerHTML='<span class="status-dot off"></span><%= lang==="ar"?"معطّل":"Disabled" %>'; }
    });

    /* Build payload */
    function buildPayload() {
      const payload = { enable: document.getElementById('global-enable').checked };
      const gwl = document.getElementById('global-wl-chips');
      if (gwl) payload.whitelist_roles = Array.from(gwl.querySelectorAll('.role-chip[data-rid]')).map(c=>c.dataset.rid);
      ['anti_ban','anti_kick','anti_channel_create','anti_channel_delete','anti_role_create','anti_role_delete','anti_bots','anti_webhooks'].forEach(mod => {
        const eEl = document.querySelector(`[data-key="${mod}:enabled"]`);
        const aEl = document.querySelector(`[data-key="${mod}:action"]`);
        const lEl = document.querySelector(`[data-key="${mod}:limit"]`);
        const cEl = document.getElementById(`${mod}-chips`);
        payload[mod] = { enabled: eEl?eEl.checked:false, action: aEl?aEl.value:'2' };
        if (lEl) payload[mod].limit = parseInt(lEl.value,10)||5;
        if (cEl) payload[mod].whitelist_roles = Array.from(cEl.querySelectorAll('.role-chip[data-rid]')).map(c=>c.dataset.rid);
      });
      return payload;
    }

    /* Save */
    document.getElementById('save-btn')?.addEventListener('click', async () => {
      const btn = document.getElementById('save-btn');
      btn.disabled = true; btn.textContent = '<%= lang==="ar"?"جارٍ الحفظ...":"Saving..." %>';
      try {
        const res = await fetch(`/dashboard/${GUILD_ID}/protection/save`, {
          method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(buildPayload())
        });
        const j = await res.json();
        if (res.ok) { showToast('<%= lang==="ar"?"تم الحفظ بنجاح ✓":"Saved successfully ✓" %>', 'success'); captureSnapshot(); checkDirty(); }
        else         showToast(j.error||'<%= lang==="ar"?"حدث خطأ":"Error occurred" %>', 'error');
      } catch(e) { showToast('<%= lang==="ar"?"فشل الاتصال":"Connection failed" %>', 'error'); }
      finally {
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg><%= lang==="ar"?"حفظ":"Save" %>';
      }
    });

    document.getElementById('reset-btn')?.addEventListener('click', () => location.reload());

    /* Role pickers – portalled to <body> to escape backdrop-filter containing block */
    function _closeAllPickers() {
      document.querySelectorAll('.role-picker-dd.open').forEach(dd => {
        dd.classList.remove('open');
        if (dd._origParent) { dd._origParent.appendChild(dd); dd._origParent = null; }
        dd.style.top = ''; dd.style.left = '';
      });
    }
    function toggleRolePicker(ddId) {
      const dd = document.getElementById(ddId); if (!dd) return;
      const isOpen = dd.classList.contains('open');
      _closeAllPickers();
      if (!isOpen) {
        const btn = dd._origParent ? dd._origParent.querySelector('.role-add-btn') : dd.previousElementSibling;
        const r   = btn.getBoundingClientRect();
        dd._origParent = dd.parentElement;
        document.body.appendChild(dd);  /* escape backdrop-filter containing block */
        dd.style.position = 'fixed';
        const ddW = 220;  /* min-width from CSS */
        let left = r.left;
        /* clamp so dropdown never overflows right edge */
        if (left + ddW > window.innerWidth - 8) left = window.innerWidth - ddW - 8;
        if (left < 8) left = 8;
        dd.style.top  = (r.bottom + 5) + 'px';
        dd.style.left = left + 'px';
        dd.classList.add('open');
      }
    }
    window.addEventListener('scroll', _closeAllPickers, true);
    window.addEventListener('resize', _closeAllPickers);
    document.addEventListener('click', e => {
      if (!e.target.closest('.role-picker-wrap') && !e.target.closest('.role-picker-dd')) _closeAllPickers();
    });
    function addGlobalRole(id, name, color) {
      const wrap = document.getElementById('global-wl-chips');
      if (wrap.querySelector(`.role-chip[data-rid="${id}"]`)) return;
      const chip = document.createElement('span'); chip.className='role-chip'; chip.dataset.rid=id;
      chip.innerHTML=`<span class="role-chip-dot" style="background:${color}"></span><span>${name}</span><button class="role-chip-rm" onclick="removeGlobalRole('${id}')">×</button>`;
      wrap.insertBefore(chip, document.getElementById('global-wl-picker-wrap'));
      _closeAllPickers(); checkDirty();
    }
    function removeGlobalRole(id) {
      document.querySelector(`#global-wl-chips .role-chip[data-rid="${id}"]`)?.remove(); checkDirty();
    }
    function addModRole(mod, id, name, color) {
      const wrap = document.getElementById(`${mod}-chips`);
      if (!wrap||wrap.querySelector(`.role-chip[data-rid="${id}"]`)) return;
      const pickerWrap = wrap.querySelector('.role-picker-wrap');
      const chip = document.createElement('span'); chip.className='role-chip'; chip.dataset.rid=id;
      chip.innerHTML=`<span class="role-chip-dot" style="background:${color}"></span><span>${name}</span><button class="role-chip-rm" onclick="removeModRole('${mod}','${id}')">×</button>`;
      wrap.insertBefore(chip, pickerWrap);
      _closeAllPickers(); checkDirty();
    }
    function removeModRole(mod, id) {
      document.querySelector(`#${mod}-chips .role-chip[data-rid="${id}"]`)?.remove(); checkDirty();
    }

    /* Toast */
    function showToast(msg, type='success') {
      const el = document.getElementById('toast');
      el.textContent=msg; el.className=`toast ${type}`;
      setTimeout(()=>el.classList.add('show'),10);
      setTimeout(()=>el.classList.remove('show'),3500);
    }

    /* Language */
    document.getElementById('lang-select').addEventListener('change', function() {
      const u = new URL(window.location.href); u.searchParams.set('lang',this.value); window.location.href=u.toString();
    });

    /* Mobile nav */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');
    const sortBtn     = document.getElementById('mgmt-sort-btn');
    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; }
    const navSidebar = document.querySelector('.nav-sidebar');
    function openNav()  { if(navSidebar){ navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow='hidden'; } }
    function closeNav() { if(navSidebar){ navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow=''; } }
    if (menuToggle) menuToggle.addEventListener('click', e=>{ e.stopPropagation(); mgmtSidebar.classList.contains('open')?closeMgmt():openMgmt(); });
    if (navOverlay) navOverlay.addEventListener('click', ()=>{ closeMgmt(); closeNav(); });
    /* Sort btn = open nav-sidebar (guild list), same as levels page */
    if (sortBtn) sortBtn.addEventListener('click', ()=>{ navSidebar&&navSidebar.classList.contains('open')?closeNav():( closeMgmt(), openNav() ); });
    document.addEventListener('keydown', e=>{ if(e.key==='Escape'){ closeMgmt(); closeNav(); } });

    /* Section collapse */
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const body = this.nextElementSibling;
        body.classList.toggle('open'); this.classList.toggle('open');
      });
    });

    /* Page transitions */
    function fadeOut(href) {
      const ov = document.getElementById('ov'); ov.classList.add('leave');
      setTimeout(()=>{ window.location.href=href; }, 360);
    }
    document.querySelectorAll('a.nav-link').forEach(a => {
      a.addEventListener('click', function(e) {
        if (this.target==='_blank') return;
        e.preventDefault(); fadeOut(this.href);
      });
    });

    /* Starfield */
    (function() {
      const c = document.getElementById('c');
      if (!window.THREE||!c) return;
      const renderer = new THREE.WebGLRenderer({canvas:c,alpha:true,antialias:false});
      renderer.setPixelRatio(Math.min(devicePixelRatio,2)); renderer.setSize(innerWidth,innerHeight);
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(70,innerWidth/innerHeight,0.1,500); camera.position.z=1;
      const N=2800, pos=new Float32Array(N*3);
      for (let i=0;i<N*3;i++) pos[i]=(Math.random()-.5)*240;
      const geo=new THREE.BufferGeometry(); geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
      const mat=new THREE.PointsMaterial({color:0xb8b0ff,size:.24,transparent:true,opacity:.45,depthWrite:false});
      scene.add(new THREE.Points(geo,mat));
      let mx=0,t=0;
      document.addEventListener('mousemove',e=>{mx=(e.clientX/innerWidth-.5)*.25;});
      window.addEventListener('resize',()=>{camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight);});
      const stars=scene.children[0];
      (function render(){requestAnimationFrame(render);t+=.00022;stars.rotation.y=t+mx*.15;renderer.render(scene,camera);})();
    })();

    captureSnapshot();
  </script>
</body>
</html>

