            <svg class="mgmt-sec-chevron" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 18 18"><path d="M9.53,4.72c-.293-.293-.768-.293-1.061,0L2.22,10.97c-.293,.293-.293,.768,0,1.061s.768,.293,1.061,0l5.72-5.72,5.72,5.72c.146,.146,.338,.22,.53,.22s.384-.073,.53-.22c.293-.293,.293-.768,0-1.061l-6.25-6.25Z" fill="currentColor"/></svg>
          </button>
          <div class="mgmt-sec-body open">
            <a href="/dashboard/<%= guildId %>/setting" class="mgmt-item nav-link">
              <div class="mgmt-item-indicator"></div>
              <div class="mgmt-item-icon"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 18 18"><path d="M9 11.5C10.3807 11.5 11.5 10.3807 11.5 9C11.5 7.6193 10.3807 6.5 9 6.5C7.6193 6.5 6.5 7.6193 6.5 9C6.5 10.3807 7.6193 11.5 9 11.5Z" fill="currentColor"/><path opacity="0.4" fill-rule="evenodd" clip-rule="evenodd" d="M7.6853 1.5H10.3147C10.7234 1.5 11.0941 1.7443 11.2629 2.1191L11.8071 3.3564C12.3536 3.5819 12.8668 3.8791 13.3352 4.237L14.6429 3.9095C15.0369 3.8108 15.4509 3.9764 15.6553 4.3295L16.9699 6.6705C17.1743 7.0235 17.1014 7.4708 16.7954 7.7392L15.7702 8.636C15.7899 8.757 15.8 8.876 15.8 9C15.8 9.124 15.7899 9.243 15.7702 9.364L16.7954 10.2608C17.1014 10.5292 17.1743 10.9765 16.9699 11.3295L15.6553 13.6705C15.4509 14.0236 15.0369 14.1892 14.6429 14.0905L13.3352 13.763C12.8668 14.1209 12.3536 14.4181 11.8071 14.6436L11.2629 15.8809C11.0941 16.2557 10.7234 16.5 10.3147 16.5H7.6853C7.2766 16.5 6.9059 16.2557 6.7371 15.8809L6.1929 14.6436C5.6464 14.4181 5.1332 14.1209 4.6648 13.763L3.3571 14.0905C2.9631 14.1892 2.5491 14.0236 2.3447 13.6705L1.0301 11.3295C0.8257 10.9765 0.8986 10.5292 1.2046 10.2608L2.2298 9.364C2.2101 9.243 2.2 9.124 2.2 9C2.2 8.876 2.2101 8.757 2.2298 8.636L1.2046 7.7392C0.8986 7.4708 0.8257 7.0235 1.0301 6.6705L2.3447 4.3295C2.5491 3.9764 2.9631 3.8108 3.3571 3.9095L4.6648 4.237C5.1332 3.8791 5.6464 3.5819 6.1929 3.3564L6.7371 2.1191C6.9059 1.7443 7.2766 1.5 7.6853 1.5Z" fill="currentColor"/></svg></div>
              <span class="mgmt-item-label"><%= lang === 'ar' ? 'الإعدادات' : 'Settings' %></span>
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom user bar -->
    <div class="mgmt-footer">
      <div class="mgmt-footer-user">
        <% if (user.avatar) { %>
          <img class="mgmt-footer-av"
            src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png?size=64"
            alt="<%= user.displayName || user.username %>" />
        <% } else { %>
          <div class="mgmt-footer-av-fallback"><%= (user.displayName || user.username).charAt(0).toUpperCase() %></div>
        <% } %>
        <span class="mgmt-footer-name">@<%= user.username %></span>
      </div>
      <button class="mgmt-footer-dots open-profile-btn" aria-label="User menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 18 18">
          <circle cx="9" cy="9" r="1.25" fill="currentColor"/>
          <circle cx="3.25" cy="9" r="1.25" fill="currentColor"/>
          <circle cx="14.75" cy="9" r="1.25" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </aside>

  <!-- Main content -->
  <main class="main">
    <!-- Overview section -->
    <section>
      <div class="section-heading">
        <div class="section-heading-icon">
          <i data-lucide="layout-dashboard" style="width:16px;height:16px;stroke:var(--purple-l);"></i>
        </div>
        <h2>
          <%= t.guild.overview %>
        </h2>
      </div>

      <div class="stats-grid">
        <!-- Level card -->
        <div class="stat-card">
          <div class="stat-info">
            <div class="stat-label">
              <%= t.guild.levelLabel %>
            </div>
            <% if (userLevel && userLevel.level !=null) { %>
              <div class="stat-value">
                <%= userLevel.level %>
              </div>
              <% } else { %>
                <div class="stat-value no-data">
                  <%= t.guild.noData %>
                </div>
                <% } %>
          </div>
          <div class="stat-icon-wrap">
            <i data-lucide="zap" style="width:22px;height:22px;stroke:var(--purple-l);fill:rgba(255, 0, 0,.12);"></i>
          </div>
        </div>

        <!-- Rank card -->
        <div class="stat-card">
          <div class="stat-info">
            <div class="stat-label">
              <%= t.guild.rankLabel %>
            </div>
            <% if (rank !=null) { %>
              <div class="stat-value">
                <%= rank %>
              </div>
              <% } else { %>
                <div class="stat-value no-data">
                  <%= t.guild.noData %>
                </div>
                <% } %>
          </div>
          <div class="stat-icon-wrap cyan">
            <i data-lucide="award" style="width:22px;height:22px;stroke:var(--cyan-l);fill:rgba(6,182,212,.1);"></i>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <a class="footer-logo" href="https://discord.gg/jfFSmVM5kK" target="_blank">
      <img src="https://res.cloudinary.com/difucqa9h/image/upload/v1770643265/discord_images/yaix1pbnbdv3srvf12gl.png"
        alt="CODE NEXUS" />
      <span>CODE NEXUS</span>
    </a>
    <p>
      <%= t.home.footerRights %>
    </p>
  </footer>

  <!-- Lucide -->
  <script src="/js/lucide.min.js"></script>
  <script>lucide.createIcons();</script>

  <!-- Stars -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  <script>
    (function () {
      const canvas = document.getElementById('c');
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: false });
      renderer.setPixelRatio(1); renderer.setSize(innerWidth, innerHeight);
      renderer.setClearColor(0x040010, 1);
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(70, innerWidth / innerHeight, 0.1, 500);
      camera.position.z = 1;
      const N = 2800, pos = new Float32Array(N * 3);
      for (let i = 0; i < N * 3; i++) pos[i] = (Math.random() - .5) * 240;
      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      const mat = new THREE.PointsMaterial({ color: 0xb8b0ff, size: 0.24, transparent: true, opacity: 0.45, depthWrite: false });
      scene.add(new THREE.Points(geo, mat));
      let mx = 0, t = 0;
      document.addEventListener('mousemove', e => { mx = (e.clientX / innerWidth - .5) * .25; });
      window.addEventListener('resize', () => { camera.aspect = innerWidth / innerHeight; camera.updateProjectionMatrix(); renderer.setSize(innerWidth, innerHeight); });
      const stars = scene.children[0];
      (function render() { requestAnimationFrame(render); t += 0.00022; stars.rotation.y = t + mx * .15; renderer.render(scene, camera); })();
    })();
  </script>

  <!-- Page in overlay -->
  <div id="ov"
    style="position:fixed;inset:0;z-index:9999;background:#000000;animation:pIn .45s cubic-bezier(.4,0,.2,1) forwards;pointer-events:none;">
  </div>
  <style>
    @keyframes pIn {
      from {
        opacity: 1
      }

      to {
        opacity: 0
      }
    }

    @keyframes pOut {
      from {
        opacity: 0
      }

      to {
        opacity: 1
      }
    }

    #ov.leave {
      animation: pOut .35s cubic-bezier(.4, 0, .2, 1) forwards;
      pointer-events: all;
    }
  </style>

  <script>
    /* ── Banner solid color ── */
    const bannerSolid = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;

    /* ── Profile sidebar ── */
    const profSidebar = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn = document.getElementById('open-profile');
    const closeBtn = document.getElementById('close-profile');
    const copyId = document.getElementById('prof-copy-id');

    function openProfile() { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
    function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }

    openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });

    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '✓ Copied!';
          copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }

    /* ── Language select ── */
    const langSelectEl = document.getElementById('lang-select');
    if (langSelectEl) {
      langSelectEl.addEventListener('change', function () {
        const u = new URL(window.location.href);
        u.searchParams.set('lang', this.value);
        window.location.href = u.toString();
      });
    }

    /* ── Mobile nav toggle (mgmt sidebar) ── */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');

    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow = ''; }
    function openNav()   { if (navSidebar) { navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; } }
    function closeNav()  { if (navSidebar) { navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow = ''; } }

    if (menuToggle) menuToggle.addEventListener('click', () => mgmtSidebar.classList.contains('open') ? closeMgmt() : openMgmt());
    if (navOverlay) navOverlay.addEventListener('click', () => { closeMgmt(); closeNav(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeMgmt(); closeNav(); closeProfile(); } });

    /* Sort button in mgmt header = toggle server switcher panel */
    const sortBtn = document.querySelector('.mgmt-sort-btn');
    if (sortBtn) {
      sortBtn.addEventListener('click', function () {
        if (navSidebar && navSidebar.classList.contains('open')) {
          closeNav();
        } else {
          closeMgmt();
          openNav();
        }
      });
    }

    /* ── Mgmt section collapse ── */
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const body = this.nextElementSibling;
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        this.classList.toggle('open', !isOpen);
      });
    });

    /* ── Page transitions ── */
    function fadeOut(href) {
      const ov = document.getElementById('ov');
      ov.classList.add('leave');
      setTimeout(() => { window.location.href = href; }, 360);
    }
    document.querySelectorAll('a.nav-link, a#logout-link').forEach(a => {
      a.addEventListener('click', function (e) {
        if (this.target === '_blank') return;
        e.preventDefault(); fadeOut(this.href);
      });
    });
  </script>
</body>

</html>
