      </div>
      <h3><%= t.tickets.settingsTitle %></h3>
    </div>

    <div class="settings-nav-grid">
      <!-- General Settings -->
      <a href="/dashboard/<%= guildId %>/tickets/general" class="settings-nav-card">
        <div class="snc-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 18 18"><path d="M9 11.5C10.3807 11.5 11.5 10.3807 11.5 9C11.5 7.6193 10.3807 6.5 9 6.5C7.6193 6.5 6.5 7.6193 6.5 9C6.5 10.3807 7.6193 11.5 9 11.5Z" fill="currentColor"/><path opacity="0.4" fill-rule="evenodd" clip-rule="evenodd" d="M7.6853 1.5H10.3147C10.7234 1.5 11.0941 1.7443 11.2629 2.1191L11.8071 3.3564C12.3536 3.5819 12.8668 3.8791 13.3352 4.237L14.6429 3.9095C15.0369 3.8108 15.4509 3.9764 15.6553 4.3295L16.9699 6.6705C17.1743 7.0235 17.1014 7.4708 16.7954 7.7392L15.7702 8.636C15.7899 8.757 15.8 8.876 15.8 9C15.8 9.124 15.7899 9.243 15.7702 9.364L16.7954 10.2608C17.1014 10.5292 17.1743 10.9765 16.9699 11.3295L15.6553 13.6705C15.4509 14.0236 15.0369 14.1892 14.6429 14.0905L13.3352 13.763C12.8668 14.1209 12.3536 14.4181 11.8071 14.6436L11.2629 15.8809C11.0941 16.2557 10.7234 16.5 10.3147 16.5H7.6853C7.2766 16.5 6.9059 16.2557 6.7371 15.8809L6.1929 14.6436C5.6464 14.4181 5.1332 14.1209 4.6648 13.763L3.3571 14.0905C2.9631 14.1892 2.5491 14.0236 2.3447 13.6705L1.0301 11.3295C0.8257 10.9765 0.8986 10.5292 1.2046 10.2608L2.2298 9.364C2.2101 9.243 2.2 9.124 2.2 9C2.2 8.876 2.2101 8.757 2.2298 8.636L1.2046 7.7392C0.8986 7.4708 0.8257 7.0235 1.0301 6.6705L2.3447 4.3295C2.5491 3.9764 2.9631 3.8108 3.3571 3.9095L4.6648 4.237C5.1332 3.8791 5.6464 3.5819 6.1929 3.3564L6.7371 2.1191C6.9059 1.7443 7.2766 1.5 7.6853 1.5Z" fill="currentColor"/></svg>
        </div>
        <div class="snc-body">
          <div class="snc-title"><%= t.tickets.cardGeneral %></div>
          <div class="snc-desc"><%= t.tickets.cardGeneralDesc %></div>
        </div>
        <div class="snc-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 18l6-6-6-6"/></svg>
        </div>
      </a>

      <!-- Panels -->
      <a href="/dashboard/<%= guildId %>/tickets/panels" class="settings-nav-card nav-link">
        <div class="snc-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 18 18"><rect x="2" y="4" width="14" height="11" rx="1.75" fill="currentColor" fill-opacity="0.2" stroke="currentColor" stroke-width="1.3"/><path d="M6 8h6M6 11h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M2 7h14" stroke="currentColor" stroke-width="1.3"/></svg>
        </div>
        <div class="snc-body">
          <div class="snc-title"><%= t.tickets.cardPanels %></div>
          <div class="snc-desc"><%= t.tickets.cardPanelsDesc %></div>
        </div>
        <div class="snc-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M9 18l6-6-6-6"/></svg>
        </div>
      </a>

    </div>
  </main>

  <!-- Three.js -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  <script>
    (function () {
      const canvas = document.getElementById('c');
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: false });
      renderer.setPixelRatio(1); renderer.setSize(innerWidth, innerHeight);
      renderer.setClearColor(0x040010, 1);
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(70, innerWidth / innerHeight, 0.1, 500);
      camera.position.z = 1;
      const N = 2800, pos = new Float32Array(N * 3);
      for (let i = 0; i < N * 3; i++) pos[i] = (Math.random() - .5) * 240;
      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      const mat = new THREE.PointsMaterial({ color: 0xb8b0ff, size: 0.24, transparent: true, opacity: 0.45, depthWrite: false });
      scene.add(new THREE.Points(geo, mat));
      let mx = 0, t = 0;
      document.addEventListener('mousemove', e => { mx = (e.clientX / innerWidth - .5) * .25; });
      window.addEventListener('resize', () => { camera.aspect = innerWidth / innerHeight; camera.updateProjectionMatrix(); renderer.setSize(innerWidth, innerHeight); });
      const stars = scene.children[0];
      (function render() { requestAnimationFrame(render); t += 0.00022; stars.rotation.y = t + mx * .15; renderer.render(scene, camera); })();
    })();

    // Nav links
    document.querySelectorAll('.nav-link').forEach(a => {
      a.addEventListener('click', e => { e.preventDefault(); window.location.href = a.href; });
    });

    // Mobile menu
    const menuBtn = document.getElementById('menu-toggle');
    const sidebar = document.getElementById('mgmt-sidebar');
    const overlay = document.getElementById('nav-overlay');
    function openSidebar()  { sidebar.classList.add('open');    overlay.classList.add('open');    document.body.style.overflow = 'hidden'; }
    function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow = ''; }
    if (menuBtn) menuBtn.addEventListener('click', () => sidebar.classList.contains('open') ? closeSidebar() : openSidebar());
    if (overlay) overlay.addEventListener('click', () => closeSidebar());

    // Section collapse
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('open');
        btn.nextElementSibling.classList.toggle('open');
      });
    });

    // Language select
    document.getElementById('lang-select')?.addEventListener('change', function() {
      const url = new URL(window.location.href);
      url.searchParams.set('lang', this.value);
      window.location.href = url.toString();
    });
    // ── Analytics Charts ─────────────────────────────────────────────────────
    (function initAnalyticsCharts() {
      const GUILD = '<%= guildId %>';
      const PL    = '#a78bfa'; // purple-l
      const PD    = '#7c3aed'; // purple
      const CY    = '#67e8f9'; // cyan
      const GR    = '#34d399'; // green
      const OR    = '#fb923c'; // orange
      const MU    = 'rgba(203,194,255,.45)'; // muted text

      const BASE = {
        chart:       { background: 'transparent', toolbar: { show: false }, fontFamily: "'Inter','Tajawal',sans-serif" },
        theme:       { mode: 'dark' },
        grid:        { borderColor: 'rgba(124,58,237,.1)', strokeDashArray: 4 },
        tooltip:     { theme: 'dark', style: { fontSize: '12px' } },
        dataLabels:  { enabled: false },
        xaxis:       { axisBorder: { show: false }, axisTicks: { show: false }, labels: { style: { colors: MU, fontSize: '11px' } } },
        yaxis:       { labels: { style: { colors: MU, fontSize: '11px' } } },
        legend:      { labels: { colors: MU }, fontSize: '12px' },
      };

      function noData(id) {
        const el = document.getElementById(id);
        if (el) el.innerHTML = '<div class="chart-placeholder">— ' + (document.documentElement.lang === 'ar' ? 'لا توجد بيانات بعد' : 'No data yet') + ' —</div>';
      }

      async function render() {
        try {
          const res = await fetch('/dashboard/' + GUILD + '/tickets/charts');
          if (!res.ok) return;
          const d = await res.json();

          // 1. Line: Tickets Over Time
          if (d.ticketsOverTime.counts.some(v => v > 0)) {
            new ApexCharts(document.getElementById('chart-over-time'), {
              ...BASE,
              chart: { ...BASE.chart, type: 'line', height: 230 },
              series: [{ name: '<%= lang==="ar"?"تذاكر":"Tickets" %>', data: d.ticketsOverTime.counts }],
              colors: [PL],
              stroke: { curve: 'smooth', width: 2.5 },
              fill:   { type: 'gradient', gradient: { shade: 'dark', type: 'vertical', opacityFrom: .35, opacityTo: .02 } },
              markers:{ size: 3, colors: [PL], strokeWidth: 0 },
              xaxis:  { ...BASE.xaxis, categories: d.ticketsOverTime.dates.map(v => v.slice(5)), tickAmount: 6 },
            }).render();
          } else noData('chart-over-time');

          // 2. Donut: Open vs Closed
          if (d.openVsClosed.open + d.openVsClosed.closed > 0) {
            new ApexCharts(document.getElementById('chart-open-closed'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'donut', height: 230 },
              series: [d.openVsClosed.open, d.openVsClosed.closed],
              labels: ['<%= lang==="ar"?"مفتوحة":"Open" %>', '<%= lang==="ar"?"مغلقة":"Closed" %>'],
              colors: [PL, GR],
              plotOptions: { pie: { donut: { size: '62%', labels: { show: true, total: { show: true, color: MU, fontSize: '13px', fontWeight: 700 } } } } },
              legend: { ...BASE.legend, position: 'bottom' },
            }).render();
          } else noData('chart-open-closed');

          // 3. Bar: By Panel
          if (d.byPanel.labels.length > 0) {
            new ApexCharts(document.getElementById('chart-by-panel'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'bar', height: 230 },
              series: [{ name: '<%= lang==="ar"?"تذاكر":"Tickets" %>', data: d.byPanel.counts }],
              colors: [PD],
              fill:   { type: 'solid' },
              plotOptions: { bar: { borderRadius: 5, columnWidth: '60%', distributed: true } },
              xaxis:  { ...BASE.xaxis, categories: d.byPanel.labels },
              legend: { show: false },
            }).render();
          } else noData('chart-by-panel');

          // 4. Heatmap
          if (d.heatmap.some(s => s.data.some(p => p.y > 0))) {
            new ApexCharts(document.getElementById('chart-heatmap'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'heatmap', height: 210 },
              series: d.heatmap,
              colors: [PD],
              dataLabels: { enabled: false },
              plotOptions: { heatmap: { shadeIntensity: .85, radius: 3, colorScale: { ranges: [
                { from: 0, to: 0,  color: 'rgba(124,58,237,.07)', name: '0'   },
                { from: 1, to: 3,  color: 'rgba(124,58,237,.38)', name: '1–3'  },
                { from: 4, to: 8,  color: 'rgba(167,139,250,.65)', name: '4–8' },
                { from: 9, to: 999,color: PL,                       name: '9+' },
              ]}}},
              xaxis: { ...BASE.xaxis, labels: { style: { colors: MU, fontSize: '10px' }, rotate: 0, formatter: v => [0,6,12,18].includes(+v.split(':')[0]) ? v : '' } },
            }).render();
          } else noData('chart-heatmap');

          // 5. Horizontal Bar: Staff Response
          if (d.staffResponse.labels.length > 0) {
            new ApexCharts(document.getElementById('chart-staff-response'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'bar', height: Math.max(200, d.staffResponse.labels.length * 42) },
              series: [{ name: '<%= lang==="ar"?"متوسط (دقيقة)":"Avg (min)" %>', data: d.staffResponse.avgMin }],
              colors: [CY],
              fill:   { type: 'solid' },
              plotOptions: { bar: { horizontal: true, borderRadius: 4, barHeight: '52%' } },
              xaxis:  { ...BASE.xaxis, categories: d.staffResponse.labels },
              legend: { show: false },
              tooltip: { y: { formatter: v => v + ' min' } },
            }).render();
          } else noData('chart-staff-response');

          // 6. Area: Resolution Over Time
          if (d.resolutionOverTime.avgMin.some(v => v !== null)) {
            new ApexCharts(document.getElementById('chart-resolution'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'area', height: 230 },
              series: [{ name: '<%= lang==="ar"?"متوسط (دقيقة)":"Avg (min)" %>', data: d.resolutionOverTime.avgMin }],
              colors: [GR],
              stroke: { curve: 'smooth', width: 2 },
              fill:   { type: 'gradient', gradient: { opacityFrom: .35, opacityTo: .02 } },
              markers:{ size: 3, colors: [GR], strokeWidth: 0 },
              xaxis:  { ...BASE.xaxis, categories: d.resolutionOverTime.dates.map(v => v.slice(5)), tickAmount: 6 },
              tooltip: { y: { formatter: v => v !== null ? v + ' min' : '—' } },
            }).render();
          } else noData('chart-resolution');

          // 7. Horizontal Bar: Staff Tickets
          if (d.staffTickets.labels.length > 0) {
            new ApexCharts(document.getElementById('chart-staff-tickets'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'bar', height: Math.max(200, d.staffTickets.labels.length * 42) },
              series: [{ name: '<%= lang==="ar"?"تذاكر مُغلقة":"Closed" %>', data: d.staffTickets.counts }],
              colors: [OR],
              fill:   { type: 'solid' },
              plotOptions: { bar: { horizontal: true, borderRadius: 4, barHeight: '52%' } },
              xaxis:  { ...BASE.xaxis, categories: d.staffTickets.labels },
              legend: { show: false },
            }).render();
          } else noData('chart-staff-tickets');

          // 8. Donut: Escalated
          if (d.escalated.normal + d.escalated.escalated > 0) {
            new ApexCharts(document.getElementById('chart-escalated'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'donut', height: 230 },
              series: [d.escalated.normal, d.escalated.escalated],
              labels: ['<%= lang==="ar"?"عادي":"Normal" %>', '<%= lang==="ar"?"مصعّد":"Escalated" %>'],
              colors: [PL, OR],
              plotOptions: { pie: { donut: { size: '62%', labels: { show: true, total: { show: true, color: MU, fontSize: '13px', fontWeight: 700 } } } } },
              legend: { ...BASE.legend, position: 'bottom' },
            }).render();
          } else noData('chart-escalated');

          // 9. Bar: Daily / Weekly / Monthly
          if (d.dailyWeeklyMonthly) {
            const dwm = d.dailyWeeklyMonthly;
            if (dwm.last7.counts.some(v => v > 0)) {
              new ApexCharts(document.getElementById('chart-daily-weekly-monthly'), {
                ...BASE,
                chart: { ...BASE.chart, type: 'bar', height: 220 },
                series: [{ name: '<%= lang==="ar"?"المستلمة":"Received" %>', data: dwm.last7.counts }],
                colors: ['#7c3aed'],
                fill: { type: 'gradient', gradient: { shade: 'dark', type: 'vertical', opacityFrom: .9, opacityTo: .5 } },
                plotOptions: { bar: { borderRadius: 5, columnWidth: '55%', distributed: true } },
                xaxis: { ...BASE.xaxis, categories: dwm.last7.dates.map(v => v.slice(5)) },
                legend: { show: false },
                annotations: {
                  yaxis: [{
                    y: dwm.summary.weekly / 7,
                    borderColor: '#a78bfa',
                    borderWidth: 1,
                    strokeDashArray: 4,
                    label: { text: '<%= lang==="ar"?"متوسط أسبوعي":"7d avg" %>', style: { color: '#a78bfa', background: 'transparent', fontSize: '10px' } },
                  }],
                },
              }).render();
            } else {
              noData('chart-daily-weekly-monthly');
            }
            // Summary badges
            const bdg = document.getElementById('chart-dwm-badges');
            if (bdg) {
              const lbl = (k, v) => `<span style="display:inline-flex;align-items:center;gap:5px;background:rgba(124,58,237,.12);border:1px solid rgba(124,58,237,.2);border-radius:8px;padding:4px 10px;font-size:.75rem;color:var(--white);">${k}<strong style="color:var(--purple-l)">${v}</strong></span>`;
              bdg.innerHTML = lbl('<%= lang==="ar"?"اليوم: ":"Today: " %>', dwm.summary.daily)
                            + lbl('<%= lang==="ar"?"الأسبوع: ":"This Week: " %>', dwm.summary.weekly)
                            + lbl('<%= lang==="ar"?"الشهر: ":"This Month: " %>', dwm.summary.monthly);
            }
          }

          // 10. H-Bar: Staff Received
          if (d.staffReceived && d.staffReceived.labels.length > 0) {
            new ApexCharts(document.getElementById('chart-staff-received'), {
              ...BASE,
              chart: { ...BASE.chart, type: 'bar', height: Math.max(200, d.staffReceived.labels.length * 42) },
              series: [{ name: '<%= lang==="ar"?"تذاكر":"Tickets" %>', data: d.staffReceived.counts }],
              colors: ['#a78bfa'],
              fill: { type: 'gradient', gradient: { shade: 'dark', type: 'horizontal', opacityFrom: .9, opacityTo: .5 } },
              plotOptions: { bar: { horizontal: true, borderRadius: 4, barHeight: '52%', distributed: true } },
              xaxis:  { ...BASE.xaxis, categories: d.staffReceived.labels },
              legend: { show: false },
            }).render();
          } else noData('chart-staff-received');

          // ── Feedback charts ────────────────────────────────────────────────────────────
          // Populate summary badges
          if (d.ratingsOverTime && d.ratingsOverTime.summary) {
            const s = d.ratingsOverTime.summary;
            const setT = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
            setT('fb-total',   s.total  || 0);
            setT('fb-daily',   s.daily  || 0);
            setT('fb-weekly',  s.weekly || 0);
            setT('fb-monthly', s.monthly|| 0);
            if (s.total > 0 && d.starDist) {
              const totalStars = d.starDist.counts.reduce((a, v, i) => a + v * (i + 1), 0);
              const avgRating  = (totalStars / s.total).toFixed(2);
              const avgEl = document.getElementById('fb-avg-score');
              const starEl = document.getElementById('fb-avg-stars');
              if (avgEl) avgEl.textContent = avgRating;
              if (starEl) {
                const filled = Math.round(avgRating);
                starEl.textContent = '★'.repeat(filled) + '☆'.repeat(5 - filled);
              }
            }
          }

          // 11. Star Rating Distribution — Donut
          if (d.starDist && d.starDist.counts.some(v => v > 0)) {
            new ApexCharts(document.getElementById('chart-star-dist'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'donut', height: 260 },
              series: d.starDist.counts,
              labels: ['1 ★', '2 ★★', '3 ★★★', '4 ★★★★', '5 ★★★★★'],
              colors: ['#ef4444', '#f97316', '#eab308', '#84cc16', '#22c55e'],
              plotOptions: { pie: { donut: {
                size: '65%',
                labels: { show: true, total: {
                  show: true, label: '<%= lang==="ar"?"المجموع":"Total" %>',
                  color: 'rgba(203,194,255,.7)', fontSize: '13px', fontWeight: 700
                }}
              }}},
              legend: { ...BASE.legend, position: 'bottom' },
              tooltip: { y: { formatter: (v, { seriesIndex }) => v + ' تقييم (' + ['1★','2★★','3★★★','4★★★★','5★★★★★'][seriesIndex] + ')' } },
            }).render();
          } else noData('chart-star-dist');

          // 12. Ratings by Panel — Bar
          if (d.ratingsByPanel && d.ratingsByPanel.labels.length > 0) {
            new ApexCharts(document.getElementById('chart-ratings-by-panel'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'bar', height: 260 },
              series: [{ name: '<%= lang==="ar"?"متوسط التقييم":"Avg Rating" %>', data: d.ratingsByPanel.avgs }],
              colors: ['#fbbf24'],
              fill: { type: 'gradient', gradient: { shade: 'dark', type: 'vertical', opacityFrom: .9, opacityTo: .55 } },
              plotOptions: { bar: { borderRadius: 5, columnWidth: '55%', distributed: true } },
              xaxis:  { ...BASE.xaxis, categories: d.ratingsByPanel.labels },
              yaxis:  { ...BASE.yaxis, min: 0, max: 5, tickAmount: 5, labels: { ...BASE.yaxis.labels, formatter: v => v + '★' } },
              legend: { show: false },
              tooltip: { y: { formatter: v => v + ' / 5' } },
              annotations: { yaxis: [{
                y: 4, borderColor: 'rgba(251,191,36,.4)', borderWidth: 1, strokeDashArray: 4,
                label: { text: '4.0', style: { color: '#fbbf24', background: 'transparent', fontSize: '10px' } },
              }]},
            }).render();
          } else noData('chart-ratings-by-panel');

          // 13. Ratings Over Time — Area
          if (d.ratingsOverTime && d.ratingsOverTime.avgRating.some(v => v !== null)) {
            new ApexCharts(document.getElementById('chart-ratings-over-time'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'area', height: 230 },
              series: [{ name: '<%= lang==="ar"?"متوسط التقييم":"Avg Rating" %>', data: d.ratingsOverTime.avgRating }],
              colors: ['#fbbf24'],
              stroke: { curve: 'smooth', width: 2.5 },
              fill:   { type: 'gradient', gradient: { opacityFrom: .35, opacityTo: .02 } },
              markers:{ size: 3, colors: ['#fbbf24'], strokeWidth: 0 },
              xaxis:  { ...BASE.xaxis, categories: d.ratingsOverTime.dates.map(v => v.slice(5)), tickAmount: 6 },
              yaxis:  { ...BASE.yaxis, min: 0, max: 5, tickAmount: 5, labels: { ...BASE.yaxis.labels, formatter: v => v + '★' } },
              tooltip: { y: { formatter: v => v !== null ? v + ' / 5' : '—' } },
            }).render();
          } else noData('chart-ratings-over-time');

          // 14. Staff Avg Rating — Horizontal Bar
          if (d.staffRatings && d.staffRatings.labels.length > 0) {
            new ApexCharts(document.getElementById('chart-staff-ratings'), {
              ...BASE,
              chart:  { ...BASE.chart, type: 'bar', height: Math.max(200, d.staffRatings.labels.length * 44) },
              series: [{ name: '<%= lang==="ar"?"متوسط التقييم":"Avg Rating" %>', data: d.staffRatings.avgs }],
              colors: ['#fbbf24'],
              fill: { type: 'gradient', gradient: { shade: 'dark', type: 'horizontal', opacityFrom: .9, opacityTo: .5 } },
              plotOptions: { bar: { horizontal: true, borderRadius: 4, barHeight: '52%', distributed: true } },
              xaxis:  { ...BASE.xaxis, categories: d.staffRatings.labels, min: 0, max: 5,
                        labels: { ...BASE.xaxis.labels, formatter: v => v + '★' } },
              legend: { show: false },
              tooltip: { y: { formatter: (v, { dataPointIndex }) => v + ' / 5 (' + d.staffRatings.counts[dataPointIndex] + ' <%= lang==="ar"?"تقييم":"ratings" %>)' } },
            }).render();
          } else noData('chart-staff-ratings');

        } catch (e) { console.warn('[charts]', e); }
      }

      // Load ApexCharts: try local first, fallback to CDN
      function boot() {
        if (window.ApexCharts) { render(); return; }
        const s = document.createElement('script');
        s.src = '/apexcharts.js';
        s.onerror = () => {
          // Fallback to CDN if local not found
          const cdn = document.createElement('script');
          cdn.src = 'https://cdn.jsdelivr.net/npm/apexcharts@3/dist/apexcharts.min.js';
          cdn.onload = render;
          document.head.appendChild(cdn);
        };
        s.onload = render;
        document.head.appendChild(s);
      }

      // Boot immediately — no lazy-load delay
      boot();

      // ── Socket.io real-time refresh ────────────────────────────────────
      (function connectSocket() {
        const si = document.createElement('script');
        si.src = '/socket.io/socket.io.js';
        si.onload = () => {
          try {
            const socket = window.io();
            socket.emit('join:guild', '<%= guildId %>');
            socket.on('tickets:update', () => { render(); });
          } catch (_e) { /* ignore if socket.io unavailable */ }
        };
        document.head.appendChild(si);
      })();
    })();
    // ── Enable / Disable toggle ──────────────────────────────────────────────
    (function initEnableToggle() {
      const cb = document.getElementById('ticket-enable');
      if (!cb) return;
      let _saving = false;
      cb.addEventListener('change', async function () {
        if (_saving) return;
        _saving = true;
        cb.disabled = true;
        const label = cb.closest('label');
        if (label) label.style.opacity = '.6';
        try {
          const res = await fetch('/dashboard/<%= guildId %>/tickets/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ enabled: cb.checked }),
          });
          const data = await res.json();
          if (!res.ok || !data.success) {
            // Revert on failure
            cb.checked = !cb.checked;
            console.error('[toggle]', data);
          }
        } catch (err) {
          cb.checked = !cb.checked;
          console.error('[toggle]', err);
        } finally {
          _saving = false;
          cb.disabled = false;
          if (label) label.style.opacity = '';
        }
      });
    })();
    // ── Footer user popup ────────────────────────────────────────────────────
    (function initFooterPopup() {
      const dotsBtn = document.getElementById('footer-dots-btn');
      const popup   = document.getElementById('footer-popup');
      if (!dotsBtn || !popup) return;

      dotsBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        popup.classList.toggle('open');
      });

      document.addEventListener('click', (e) => {
        if (!popup.contains(e.target) && e.target !== dotsBtn) {
          popup.classList.remove('open');
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') popup.classList.remove('open');
      });
    })();

    // ── Guild sort (nav-sidebar) ─────────────────────────────────────────────
    (function initGuildSort() {
      const sortBtn    = document.getElementById('mgmt-sort-btn');
      const navSidebar = document.querySelector('.nav-sidebar');
      if (!sortBtn || !navSidebar) return;

      const navItems   = Array.from(navSidebar.querySelectorAll('.nav-item'));
      const origOrder  = navItems.slice();
      let   sorted     = false;

      sortBtn.addEventListener('click', () => {
        sorted = !sorted;
        sortBtn.classList.toggle('sorted', sorted);

        const ordered = sorted
          ? navItems.slice().sort((a, b) => {
              const na = (a.querySelector('.nav-item-name')?.textContent || '').trim().toLowerCase();
              const nb = (b.querySelector('.nav-item-name')?.textContent || '').trim().toLowerCase();
              return na.localeCompare(nb);
            })
          : origOrder;

        const divider = navSidebar.querySelector('.nav-divider');
        const after   = divider ? divider.nextSibling : null;
        ordered.forEach(el => navSidebar.insertBefore(el, after));
      });
    })();

    // ── Real-time stats polling ──────────────────────────────────────────────
    (function initStatsPolling() {
      const GUILD_ID   = '<%= guildId %>';
      const POLL_MS    = 10000; // 10 s

      const elOpen    = document.getElementById('stat-open');
      const elClaimed = document.getElementById('stat-claimed');
      const elClosed  = document.getElementById('stat-closed-today');
      const elAvg     = document.getElementById('stat-avg');
      const elLimit   = document.getElementById('stat-limit');

      function setVal(el, val, muted) {
        if (!el) return;
        el.textContent = val;
        el.classList.toggle('muted-val', !!muted);
      }

      function pulse(el) {
        if (!el) return;
        el.style.transition = 'opacity .15s';
        el.style.opacity    = '0.3';
        setTimeout(() => { el.style.opacity = '1'; }, 160);
      }

      async function fetchStats() {
        try {
          const res  = await fetch(`/dashboard/${GUILD_ID}/tickets/stats`);
          if (!res.ok) return;
          const data = await res.json();

          [elOpen, elClaimed, elClosed, elAvg, elLimit].forEach(pulse);

          setVal(elOpen,    data.open,         data.open    === 0);
          setVal(elClaimed, data.claimed,       data.claimed === 0);
          setVal(elClosed,  data.closed_today,  data.closed_today === 0);
          setVal(elAvg,     data.avg_display,   data.avg_display === '—');
          setVal(elLimit,   data.limit,         false);
        } catch (_e) { /* silent */ }
      }

      setInterval(fetchStats, POLL_MS);
    })();

    /* ── Profile sidebar ── */
    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    const openBtn      = document.getElementById('open-profile');
    const closeBtn     = document.getElementById('close-profile');
    const copyId       = document.getElementById('prof-copy-id');
    const bannerSolid  = document.querySelector('.prof-banner-solid');
    if (bannerSolid && bannerSolid.dataset.bg) bannerSolid.style.background = bannerSolid.dataset.bg;
    function openProfile()  { if (!profSidebar) return; profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; }
    function closeProfile() { if (!profSidebar) return; profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
    if (openBtn)  openBtn.addEventListener('click', openProfile);
    document.querySelectorAll('.open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    if (closeBtn) closeBtn.addEventListener('click', closeProfile);
    if (profBackdrop) profBackdrop.addEventListener('click', closeProfile);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeProfile(); });
    if (copyId) {
      copyId.addEventListener('click', () => {
        navigator.clipboard.writeText(copyId.textContent.trim()).then(() => {
          const orig = copyId.textContent;
          copyId.textContent = '✓ Copied!'; copyId.style.color = 'var(--cyan-l)';
          setTimeout(() => { copyId.textContent = orig; copyId.style.color = ''; }, 1500);
        });
      });
    }
  </script>
</body>
