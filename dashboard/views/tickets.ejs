  <!-- Main Content -->
  <main class="main">
    <!-- Page Header -->
    <div class="page-header">
      <div class="page-header-left">
        <h2><%= t.tickets.pageTitle %></h2>
        <p><%= t.tickets.pageDesc %></p>
      </div>
      <label class="toggle-switch" title="<%= lang === 'ar' ? 'تفعيل / تعطيل نظام التذاكر' : 'Enable / Disable Ticket System' %>">
        <input type="checkbox" id="ticket-enable" <%= ticketSettings.ENABLE ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <div class="divider"></div>

    <!-- Stats Overview -->
    <div class="section-heading">
      <div class="section-heading-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 18 18" fill="none"><path d="M2 14V10.25C2 9.284 2.784 8.5 3.75 8.5H5.25C6.216 8.5 7 9.284 7 10.25V14H2Z" fill="var(--purple-l)"/><path d="M7.5 14V6.75C7.5 5.784 8.284 5 9.25 5H10.75C11.716 5 12.5 5.784 12.5 6.75V14H7.5Z" fill="var(--purple-l)" fill-opacity="0.6"/><path d="M13 14V3.75C13 2.784 13.784 2 14.75 2H15.25C16.216 2 17 2.784 17 3.75V14H13Z" fill="var(--purple-l)" fill-opacity="0.35"/><path d="M1 14H17" stroke="var(--purple-l)" stroke-width="1.5" stroke-linecap="round"/></svg>
      </div>
      <h3><%= lang === 'ar' ? 'إحصائيات' : 'Statistics' %></h3>
    </div>

    <div class="stats-grid">
      <!-- Total Open -->
      <div class="stat-card">
        <div class="stat-info">
          <div class="stat-label"><%= t.tickets.statOpen %></div>
          <div id="stat-open" class="stat-value <%= ticketStats.open === 0 ? 'muted-val' : '' %>"><%= ticketStats.open %></div>
        </div>
        <div class="stat-icon-wrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="11" rx="1.75" fill="var(--purple-l)" fill-opacity="0.2" stroke="var(--purple-l)" stroke-width="1.3"/><path d="M2 7h14" stroke="var(--purple-l)" stroke-width="1.3"/><circle cx="9" cy="11" r="1.5" fill="var(--purple-l)"/></svg>
        </div>
      </div>
      <!-- Claimed -->
      <div class="stat-card">
