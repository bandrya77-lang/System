  <!-- Main content -->
  <main class="main">

    <!-- Page header -->
    <div class="page-header">
      <div class="page-header-left">
        <h2><%= lang === 'ar' ? 'الرتب التلقائية' : 'Auto Roles' %></h2>
        <p><%= lang === 'ar' ? 'حدد الرتب التي تُضاف تلقائياً عند دخول أعضاء أو بوتات جديدة.' : 'Configure roles assigned automatically when humans or bots join the server.' %></p>
        <div class="page-header-badge">
          <i data-lucide="users" style="width:11px;height:11px;stroke:currentColor;"></i>
          Members
        </div>
      </div>
      <label class="sw-wrap" title="<%= lang === 'ar' ? 'تفعيل / إيقاف' : 'Enable / Disable' %>">
        <input type="checkbox" class="sw-input" id="toggle-enabled" <%= autoRoles.enabled ? 'checked' : '' %>>
        <span class="sw-track"><span class="sw-thumb"></span></span>
      </label>
    </div>

    <!-- Stats -->
    <div class="stats-strip">
      <div class="stat-card">
        <div class="stat-card-label"><%= lang === 'ar' ? 'رتب البشر' : 'Human Roles' %></div>
        <div class="stat-card-value green" id="stat-humans"><%= autoRoles.humans.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label"><%= lang === 'ar' ? 'رتب البوتات' : 'Bot Roles' %></div>
        <div class="stat-card-value cyan" id="stat-bots"><%= autoRoles.bots.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label"><%= lang === 'ar' ? 'إجمالي الرتب' : 'Total Roles' %></div>
        <div class="stat-card-value" id="stat-total"><%= autoRoles.humans.length + autoRoles.bots.length %></div>
      </div>
      <div class="stat-card">
        <div class="stat-card-label"><%= lang === 'ar' ? 'قواعد الدعوات' : 'Invite Rules' %></div>
        <div class="stat-card-value" id="stat-invites"><%= (autoRoles.inviteRoles || []).length %></div>
      </div>
    </div>

    <!-- Card: Human roles -->
    <div class="card">
      <div class="card-header">
        <div class="card-header-left">
          <div class="card-icon green">
            <i data-lucide="user-check" style="width:20px;height:20px;stroke:currentColor;"></i>
          </div>
          <div>
            <div class="card-title"><%= lang === 'ar' ? 'رتب البشر' : 'Human Roles' %></div>
            <div class="card-sub"><%= lang === 'ar' ? 'تُضاف هذه الرتب تلقائياً لكل عضو بشري جديد' : 'Added automatically to every new human member' %></div>
          </div>
        </div>
      </div>

      <div class="role-section-label">
        <span class="rs-icon human"><i data-lucide="user" style="width:13px;height:13px;stroke:currentColor;"></i></span>
        <%= lang === 'ar' ? 'الرتب المحددة' : 'Selected Roles' %>
      </div>
      <div class="roles-tags-wrap" id="human-tags">
        <% if (autoRoles.humans.length === 0) { %>
          <span class="roles-empty"><%= lang === 'ar' ? 'لا توجد رتب' : 'No roles added yet' %></span>
        <% } else { %>
          <% autoRoles.humans.forEach(rId => {
               const role = guildRoles.find(r => r.id === rId);
               if (!role) return;
          %>
            <span class="role-tag human-tag" data-id="<%= role.id %>">
              <span class="role-tag-dot"></span>
              <% if (role.color) { %><span class="rcd" data-col="<%= role.color %>" style="width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0;"></span><% } %>
              <%= role.name %>
              <button class="role-tag-rm" onclick="removeRole('humans','<%= role.id %>')" title="Remove">
                <i data-lucide="x" style="width:10px;height:10px;stroke:currentColor;"></i>
              </button>
            </span>
          <% }) %>
        <% } %>
      </div>

      <div class="role-picker-wrap" id="human-picker-wrap">
        <button class="role-picker-btn" id="human-picker-btn" onclick="togglePicker('humans')">
          <i data-lucide="plus" style="width:15px;height:15px;stroke:currentColor;color:var(--purple-l);"></i>
          <span><%= lang === 'ar' ? 'إضافة رتبة...' : 'Add a role...' %></span>
          <span class="role-picker-chevron"><i data-lucide="chevron-down" style="width:14px;height:14px;stroke:currentColor;"></i></span>
        </button>
        <div class="role-picker-dropdown" id="human-picker-dropdown">
          <div class="role-picker-search-wrap">
            <input class="role-picker-search" type="text" id="human-search" placeholder="<%= lang === 'ar' ? 'بحث...' : 'Search roles...' %>" oninput="filterRoles('humans', this.value)" />
          </div>
          <div class="role-picker-list" id="human-role-list">
            <% guildRoles.forEach(role => { %>
              <div class="role-picker-option<%= autoRoles.humans.includes(role.id) ? ' selected' : '' %>" data-type="humans" data-id="<%= role.id %>" data-name="<%= role.name %>" data-color="<%= role.color || '' %>">
                <span class="rp-dot rcd" data-col="<%= role.color || '' %>" style="background:rgba(255,255,255,.3);"></span>
                <span class="rp-name"><%= role.name %></span>
                <span class="rp-check"><i data-lucide="check" style="width:13px;height:13px;stroke:currentColor;"></i></span>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Card: Bot roles -->
    <div class="card">
      <div class="card-header">
        <div class="card-header-left">
          <div class="card-icon cyan">
            <i data-lucide="bot" style="width:20px;height:20px;stroke:currentColor;"></i>
          </div>
          <div>
            <div class="card-title"><%= lang === 'ar' ? 'رتب البوتات' : 'Bot Roles' %></div>
            <div class="card-sub"><%= lang === 'ar' ? 'تُضاف هذه الرتب تلقائياً لكل بوت جديد' : 'Added automatically to every new bot added to the server' %></div>
          </div>
        </div>
      </div>

      <div class="role-section-label">
        <span class="rs-icon bot"><i data-lucide="cpu" style="width:13px;height:13px;stroke:currentColor;"></i></span>
        <%= lang === 'ar' ? 'الرتب المحددة' : 'Selected Roles' %>
      </div>
      <div class="roles-tags-wrap" id="bot-tags">
        <% if (autoRoles.bots.length === 0) { %>
          <span class="roles-empty"><%= lang === 'ar' ? 'لا توجد رتب' : 'No roles added yet' %></span>
        <% } else { %>
          <% autoRoles.bots.forEach(rId => {
               const role = guildRoles.find(r => r.id === rId);
               if (!role) return;
          %>
            <span class="role-tag bot-tag" data-id="<%= role.id %>">
              <span class="role-tag-dot"></span>
              <% if (role.color) { %><span class="rcd" data-col="<%= role.color %>" style="width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0;"></span><% } %>
              <%= role.name %>
              <button class="role-tag-rm" onclick="removeRole('bots','<%= role.id %>')" title="Remove">
                <i data-lucide="x" style="width:10px;height:10px;stroke:currentColor;"></i>
              </button>
            </span>
          <% }) %>
        <% } %>
      </div>

      <div class="role-picker-wrap" id="bot-picker-wrap">
        <button class="role-picker-btn" id="bot-picker-btn" onclick="togglePicker('bots')">
          <i data-lucide="plus" style="width:15px;height:15px;stroke:currentColor;color:var(--cyan-l);"></i>
          <span><%= lang === 'ar' ? 'إضافة رتبة...' : 'Add a role...' %></span>
          <span class="role-picker-chevron"><i data-lucide="chevron-down" style="width:14px;height:14px;stroke:currentColor;"></i></span>
        </button>
        <div class="role-picker-dropdown" id="bot-picker-dropdown">
          <div class="role-picker-search-wrap">
            <input class="role-picker-search" type="text" id="bot-search" placeholder="<%= lang === 'ar' ? 'بحث...' : 'Search roles...' %>" oninput="filterRoles('bots', this.value)" />
          </div>
          <div class="role-picker-list" id="bot-role-list">
            <% guildRoles.forEach(role => { %>
              <div class="role-picker-option<%= autoRoles.bots.includes(role.id) ? ' selected' : '' %>" data-type="bots" data-id="<%= role.id %>" data-name="<%= role.name %>" data-color="<%= role.color || '' %>">
                <span class="rp-dot rcd" data-col="<%= role.color || '' %>" style="background:rgba(255,255,255,.3);"></span>
                <span class="rp-name"><%= role.name %></span>
                <span class="rp-check"><i data-lucide="check" style="width:13px;height:13px;stroke:currentColor;"></i></span>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Card: Invite specific roles -->
    <div class="card">
      <div class="card-header">
        <div class="card-header-left">
          <div class="card-icon purple">
            <i data-lucide="link-2" style="width:20px;height:20px;stroke:currentColor;"></i>
          </div>
          <div>
            <div class="card-title"><%= lang === 'ar' ? 'تعيين رتبة حسب رابط الدعوة' : 'Assign Role To Specific Invite' %></div>
            <div class="card-sub"><%= lang === 'ar' ? 'مثال: abc123 → YouTube Member' : 'Example: abc123 → YouTube Member' %></div>
          </div>
        </div>
      </div>

      <div class="invite-wrap" id="invite-map-list">
        <% if (!autoRoles.inviteRoles || autoRoles.inviteRoles.length === 0) { %>
          <div class="invite-empty" id="invite-empty"><%= lang === 'ar' ? 'لا توجد قواعد دعوات بعد' : 'No invite rules yet' %></div>
        <% } else { %>
          <% autoRoles.inviteRoles.forEach(ir => { %>
            <div class="invite-row">
              <input class="invite-input invite-code" placeholder="<%= lang === 'ar' ? 'كود الدعوة (مثال: abc123)' : 'Invite code (e.g. abc123)' %>" value="<%= ir.invite %>" maxlength="64" />
              <select class="invite-select invite-role">
                <option value=""><%= lang === 'ar' ? 'اختر رتبة...' : 'Select role...' %></option>
                <% guildRoles.forEach(role => { %>
                  <option value="<%= role.id %>" <%= ir.role === role.id ? 'selected' : '' %>><%= role.name %></option>
                <% }) %>
              </select>
              <button class="invite-remove" type="button" title="<%= lang === 'ar' ? 'حذف' : 'Remove' %>">
                <i data-lucide="trash-2" style="width:14px;height:14px;stroke:currentColor;"></i>
              </button>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div class="divider"></div>
      <button class="btn btn-ghost" type="button" id="add-invite-row">
        <i data-lucide="plus" style="width:14px;height:14px;stroke:currentColor;"></i>
        <%= lang === 'ar' ? 'إضافة قاعدة دعوة' : 'Add Invite Rule' %>
      </button>
    </div>

  </main><!-- /main -->

  <!-- Save bar -->
  <div class="save-bar" id="save-bar">
    <span class="save-bar-hint"><%= lang === 'ar' ? 'لديك تغييرات غير محفوظة' : 'You have unsaved changes' %></span>
    <div class="save-bar-actions">
      <button class="btn btn-ghost" id="reset-btn"><%= lang === 'ar' ? 'تراجع' : 'Reset' %></button>
      <button class="btn btn-primary" id="save-btn">
        <i data-lucide="save" style="width:15px;height:15px;stroke:currentColor;"></i>
        <%= lang === 'ar' ? 'حفظ التغييرات' : 'Save Changes' %>
      </button>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <!-- Site footer -->
  <footer class="site-footer">
    <a href="/dashboard" class="footer-logo nav-link">
      <img src="https://res.cloudinary.com/difucqa9h/image/upload/v1770643265/discord_images/yaix1pbnbdv3srvf12gl.png" alt="CODE NEXUS" />
      <span>CODE NEXUS</span>
    </a>
    <p>CODE NEXUS Dashboard © 2026</p>
  </footer>

  <script type="application/json" id="_init"><%- JSON.stringify({ enabled: autoRoles.enabled, humans: autoRoles.humans, bots: autoRoles.bots, inviteRoles: autoRoles.inviteRoles || [] }) %></script>
  <template id="invite-row-template">
    <div class="invite-row">
      <input class="invite-input invite-code" placeholder="<%= lang === 'ar' ? 'كود الدعوة (مثال: abc123)' : 'Invite code (e.g. abc123)' %>" maxlength="64" />
      <select class="invite-select invite-role">
        <option value=""><%= lang === 'ar' ? 'اختر رتبة...' : 'Select role...' %></option>
        <% guildRoles.forEach(role => { %>
          <option value="<%= role.id %>"><%= role.name %></option>
        <% }) %>
      </select>
      <button class="invite-remove" type="button" title="<%= lang === 'ar' ? 'حذف' : 'Remove' %>">
        <i data-lucide="trash-2" style="width:14px;height:14px;stroke:currentColor;"></i>
      </button>
    </div>
  </template>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script>
    lucide.createIcons();

    /* Apply data-col background colors */
    document.querySelectorAll('.rcd[data-col]').forEach(function(el) {
      if (el.dataset.col) el.style.background = el.dataset.col;
    });

    /* Event delegation for role picker options */
    document.addEventListener('click', function(e) {
      const opt = e.target.closest('.role-picker-option[data-type]');
      if (!opt) return;
      toggleRole(opt.dataset.type, opt.dataset.id, opt.dataset.name, opt.dataset.color || '');
    });

    /* ── Canvas bg ── */
    (function () {
      const canvas = document.getElementById('c');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      let W, H, stars = [];
      function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
      function initStars() { stars = Array.from({ length: 80 }, () => ({ x: Math.random() * W, y: Math.random() * H, r: Math.random() * 1.2 + .2, a: Math.random() * .6 + .1, s: Math.random() * .3 + .05 })); }
      function draw() {
        ctx.clearRect(0, 0, W, H);
        stars.forEach(s => {
          s.a += s.s * .006; if (s.a > .7 || s.a < .1) s.s *= -1;
          ctx.beginPath(); ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(167,139,250,${s.a})`; ctx.fill();
        });
        requestAnimationFrame(draw);
      }
      window.addEventListener('resize', () => { resize(); initStars(); });
      resize(); initStars(); draw();
    })();

    /* ── Profile sidebar ── */
    const profSidebar  = document.getElementById('prof-sidebar');
    const profBackdrop = document.getElementById('prof-backdrop');
    function openProfile()  { profSidebar.classList.add('open'); profBackdrop.classList.add('open'); profSidebar.removeAttribute('aria-hidden'); document.body.style.overflow = 'hidden'; }
    function closeProfile() { profSidebar.classList.remove('open'); profBackdrop.classList.remove('open'); profSidebar.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; }
    document.querySelectorAll('#open-profile, .open-profile-btn').forEach(b => b.addEventListener('click', openProfile));
    document.getElementById('close-profile').addEventListener('click', closeProfile);
    profBackdrop.addEventListener('click', closeProfile);

    /* Copy user ID */
    const profCopyId = document.getElementById('prof-copy-id');
    if (profCopyId) {
      profCopyId.addEventListener('click', () => {
        navigator.clipboard.writeText(profCopyId.textContent.trim()).then(() => showToast('<%= lang === "ar" ? "تم نسخ المعرف ✓" : "ID copied ✓" %>', 'success'));
      });
    }

    /* Profile banner color */
    document.querySelectorAll('.prof-banner-solid[data-bg]').forEach(el => {
      el.style.background = el.dataset.bg;
    });

    /* ── Language select ── */
    const langSel = document.getElementById('lang-select');
    if (langSel) {
      langSel.addEventListener('change', function () {
        const u = new URL(window.location.href);
        u.searchParams.set('lang', this.value);
        window.location.href = u.toString();
      });
    }

    /* ── Mobile nav toggle ── */
    const menuToggle  = document.getElementById('menu-toggle');
    const mgmtSidebar = document.getElementById('mgmt-sidebar');
    const navSidebar  = document.querySelector('.nav-sidebar');
    const navOverlay  = document.getElementById('nav-overlay');

    function openMgmt()  { mgmtSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeMgmt() { mgmtSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow = ''; }
    function openNav()   { if (navSidebar) { navSidebar.classList.add('open'); navOverlay.classList.add('open'); document.body.style.overflow = 'hidden'; } }
    function closeNav()  { if (navSidebar) { navSidebar.classList.remove('open'); navOverlay.classList.remove('open'); document.body.style.overflow = ''; } }

    if (menuToggle) menuToggle.addEventListener('click', () => mgmtSidebar.classList.contains('open') ? closeMgmt() : openMgmt());
    if (navOverlay) navOverlay.addEventListener('click', () => { closeMgmt(); closeNav(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeMgmt(); closeNav(); closeProfile(); } });

    const sortBtn = document.querySelector('.mgmt-sort-btn');
    if (sortBtn) {
      sortBtn.addEventListener('click', () => {
        if (navSidebar && navSidebar.classList.contains('open')) closeNav(); else { closeMgmt(); openNav(); }
      });
    }

    /* ── Mgmt section collapse ── */
    document.querySelectorAll('.mgmt-section-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const body = this.nextElementSibling;
        const isOpen = body.classList.contains('open');
        body.classList.toggle('open', !isOpen);
        this.classList.toggle('open', !isOpen);
      });
    });

    /* ── Enabled toggle ── */
    document.getElementById('toggle-enabled').addEventListener('change', markDirty);

    /* ── State ── */
    const _state = JSON.parse(document.getElementById('_init').textContent);

    function collectInviteRoles() {
      const out = [];
      document.querySelectorAll('#invite-map-list .invite-row').forEach(row => {
        const invite = (row.querySelector('.invite-code')?.value || '').trim();
        const role = (row.querySelector('.invite-role')?.value || '').trim();
        if (invite && role) out.push({ invite, role });
      });
      return out;
    }

    function updateInviteEmpty() {
      const list = document.getElementById('invite-map-list');
      if (!list) return;
      const hasRows = list.querySelector('.invite-row');
      let empty = document.getElementById('invite-empty');
      if (!hasRows && !empty) {
        empty = document.createElement('div');
        empty.id = 'invite-empty';
        empty.className = 'invite-empty';
        empty.textContent = "<%= lang === 'ar' ? 'لا توجد قواعد دعوات بعد' : 'No invite rules yet' %>";
        list.appendChild(empty);
      }
      if (hasRows && empty) empty.remove();
    }

    function addInviteRow(invite = '', role = '') {
      const list = document.getElementById('invite-map-list');
      const tpl = document.getElementById('invite-row-template');
      if (!list || !tpl) return;
      const node = tpl.content.firstElementChild.cloneNode(true);
      node.querySelector('.invite-code').value = invite;
      node.querySelector('.invite-role').value = role;
      document.getElementById('invite-empty')?.remove();
      list.appendChild(node);
      lucide.createIcons();
      markDirty();
      updateStats();
    }

    document.getElementById('add-invite-row')?.addEventListener('click', () => addInviteRow());
    document.getElementById('invite-map-list')?.addEventListener('click', (e) => {
      const rm = e.target.closest('.invite-remove');
      if (!rm) return;
      rm.closest('.invite-row')?.remove();
      updateInviteEmpty();
      markDirty();
      updateStats();
    });
    document.getElementById('invite-map-list')?.addEventListener('input', (e) => {
      if (e.target.closest('.invite-row')) markDirty();
    });
    document.getElementById('invite-map-list')?.addEventListener('change', (e) => {
      if (e.target.closest('.invite-row')) { markDirty(); updateStats(); }
    });
    updateInviteEmpty();

    /* ── Picker toggle ── */
    function pickerPrefix(type) { return type === 'humans' ? 'human' : 'bot'; }

    function togglePicker(type) {
      const pfx      = pickerPrefix(type);
      const btn      = document.getElementById(pfx + '-picker-btn');
      const dropdown = document.getElementById(pfx + '-picker-dropdown');
      const isOpen   = dropdown.classList.contains('open');
      ['human', 'bot'].forEach(p => {
        document.getElementById(p + '-picker-btn')?.classList.remove('open');
        document.getElementById(p + '-picker-dropdown')?.classList.remove('open');
      });
      if (!isOpen) {
        btn.classList.add('open');
        dropdown.classList.add('open');
        document.getElementById(pfx + '-search')?.focus();
      }
    }
    document.addEventListener('click', e => {
      if (!e.target.closest('.role-picker-wrap')) {
        ['human', 'bot'].forEach(p => {
          document.getElementById(p + '-picker-btn')?.classList.remove('open');
          document.getElementById(p + '-picker-dropdown')?.classList.remove('open');
        });
      }
    });

    /* ── Filter ── */
    function filterRoles(type, q) {
      const listId = type === 'humans' ? 'human-role-list' : 'bot-role-list';
      const list   = document.getElementById(listId);
      const lower  = q.toLowerCase();
      list.querySelectorAll('.role-picker-option').forEach(opt => {
        const name = opt.querySelector('.rp-name').textContent.toLowerCase();
        opt.style.display = name.includes(lower) ? '' : 'none';
      });
    }

    /* ── Toggle role in/out ── */
    function toggleRole(type, roleId, roleName, roleColor) {
      const arr      = _state[type];
      const idx      = arr.indexOf(roleId);
      const isAdding = idx === -1;

      if (isAdding) arr.push(roleId);
      else arr.splice(idx, 1);

      // Update dropdown option
      const listId = type === 'humans' ? 'human-role-list' : 'bot-role-list';
      const opt    = document.querySelector(`#${listId} [data-id="${roleId}"]`);
      if (opt) opt.classList.toggle('selected', isAdding);

      // Update tag cloud
      const tagsWrap = document.getElementById(type === 'humans' ? 'human-tags' : 'bot-tags');
      const existing = tagsWrap.querySelector(`[data-id="${roleId}"]`);
      if (isAdding && !existing) {
        // Remove empty placeholder
        tagsWrap.querySelector('.roles-empty')?.remove();
        const tag   = document.createElement('span');
        const cls   = type === 'humans' ? 'human-tag' : 'bot-tag';
        tag.className   = `role-tag ${cls}`;
        tag.dataset.id  = roleId;
        const colorDot  = roleColor ? `<span style="width:8px;height:8px;border-radius:50%;background:${roleColor};display:inline-block;flex-shrink:0;"></span>` : '';
        tag.innerHTML   = `<span class="role-tag-dot"></span>${colorDot}${roleName}<button class="role-tag-rm" onclick="removeRole('${type}','${roleId}')" title="Remove"><i data-lucide="x" style="width:10px;height:10px;stroke:currentColor;"></i></button>`;
        tagsWrap.appendChild(tag);
        lucide.createIcons();
      } else if (!isAdding && existing) {
        existing.remove();
        if (!tagsWrap.children.length) {
          tagsWrap.innerHTML = `<span class="roles-empty"><%= lang === 'ar' ? 'لا توجد رتب' : 'No roles added yet' %></span>`;
        }
      }

      updateStats();
      markDirty();
    }

    /* ── Remove role via tag × button ── */
    function removeRole(type, roleId) {
      toggleRole(type, roleId, '', '');
    }

    /* ── Stats ── */
    function updateStats() {
      document.getElementById('stat-humans').textContent = _state.humans.length;
      document.getElementById('stat-bots').textContent   = _state.bots.length;
      document.getElementById('stat-total').textContent  = _state.humans.length + _state.bots.length;
      const inviteEl = document.getElementById('stat-invites');
      if (inviteEl) inviteEl.textContent = collectInviteRoles().length;
    }

    /* ── Save bar ── */
    const saveBar  = document.getElementById('save-bar');
    function markDirty() { saveBar.classList.add('visible'); }

    /* ── Toast ── */
    function showToast(msg, type) {
      const t = document.getElementById('toast');
      if (!t) return;
      t.textContent = msg; t.className = 'toast ' + (type || 'success');
      void t.offsetWidth;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3000);
    }

    /* ── Reset ── */
    document.getElementById('reset-btn').addEventListener('click', () => window.location.reload());

    /* ── Save ── */
    document.getElementById('save-btn').addEventListener('click', async () => {
      const btn      = document.getElementById('save-btn');
      const origHTML = btn.innerHTML;
      btn.disabled   = true;
      btn.innerHTML  = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>&nbsp;<%= lang === "ar" ? "جاري الحفظ..." : "Saving..." %>';
      try {
        const payload = {
          enabled: document.getElementById('toggle-enabled').checked,
          memberRoles:  _state.humans,
          botRoles:     _state.bots,
          inviteRoles:  collectInviteRoles()
        };
        const res  = await fetch('/dashboard/<%= guildId %>/auto-roles/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Error');
        saveBar.classList.remove('visible');
        showToast('<%= lang === "ar" ? "تم الحفظ بنجاح ✓" : "Saved successfully ✓" %>', 'success');
      } catch (err) {
        showToast(err.message || '<%= lang === "ar" ? "حدث خطأ" : "An error occurred" %>', 'error');
      } finally {
        btn.disabled  = false;
        btn.innerHTML = origHTML;
        lucide.createIcons();
      }
    });

    /* ── Page transitions ── */
    function fadeOut(href) {
      const ov = document.getElementById('ov');
      ov.classList.add('leave');
      setTimeout(() => { window.location.href = href; }, 360);
    }
    document.querySelectorAll('a.nav-link, a#logout-link').forEach(a => {
      a.addEventListener('click', function (e) {
        if (this.target === '_blank') return;
        e.preventDefault();
        fadeOut(this.href);
      });
    });
  </script>
</body>
</html>

